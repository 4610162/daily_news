{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/2026-02-28/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-02-28)","text":""},{"location":"reports/2026-02-28/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \"3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8 \uae30\ud68c\uc778\ub370\u2026\" 40\ub300 \uc9c1\uc7a5\uc778 \uba58\ubd95 \uc628 \uae4c\ub2ed [\ub3c8 \ubc84\ub294 \ubc95 \uc544\ub07c\ub294 \ubc95]</li> <li>[\uacbd\uc81c] \ud398\ub77c\ub9ac \ud0c0\ub358 \uc190\ud765\ubbfc, 1\uc5b5\uc9dc\ub9ac \u8eca \uc6b4\uc804 \ud3ec\ucc29\u2026\ubbf8\uad6d '\ub4e4\uc369'</li> <li>[\uacbd\uc81c] \u4f0a \ub9ac\ube59 \ube0c\ub79c\ub4dc '\uc2a4\ud14c\ud310\ud50c\ub77c\uc2a4\ud2b8', \uad6d\ub0b4 \ucf54\uc2a4\ud2b8\ucf54\uc5d0 \ud5ec\ud53c\uce74\ud2b8 \ucd9c\uc2dc</li> <li>[\uacbd\uc81c] \"\ub9e4\uc77c \ub2ec\ub838\ub354\ub2c8 \ud1b5\uc7a5\uc5d0 \ub3c8 \ub4e4\uc5b4\uc640\uc694\"\u2026\ub7ec\ub2dd\uc871\ub4e4 \ud658\ud638\ud55c \uc774\uc720</li> <li>[\uacbd\uc81c] \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 2\uc8fc \uc5f0\uc18d \uc0c1\uc2b9\u2026\uacbd\uc720\ub294 \ub2e4\uc74c \uc8fc\ub3c4 \uc624\ub97c \ub4ef</li> <li>[\uc99d\uad8c] \uae00\ub85c\ubc8c \ud070\uc190 4000\uc5b5 \uc4f8\uc5b4\ub2f4\ub354\ub2c8\u2026\ud55c \ub2ec \ub9cc\uc5d0 34% '\uae09\ub4f1' [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] [\uc18d\ubcf4] \ubbf8\uad6d \uc774\ub780 \uacf5\uaca9, \ube44\ud2b8\ucf54\uc778 4% \uc774\uc0c1 \uae09\ub77d, 6\ub9cc4000\ub2ec\ub7ec \ubd95\uad34</li> <li>[\uc99d\uad8c] \ucda9\uaca9 \uc18c\uc2dd\uc5d0 \uc798\ub098\uac00\ub358 \uc8fc\uac00 '\ud718\uccad'\u2026\ud55c\uad6d\uc804\ub825 \uac1c\ubbf8 \uc5b4\uca4c\ub098 [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] \uadf8\uc57c\ub9d0\ub85c '\ud55c \ub057 \ucc28\uc774'\u2026'\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15 \ub09c \uc774\uc720 \uc788\uc5c8\ub2e4 [\ubc15\uc8fc\uc5f0\uc758 \uc5ec\uc758\ub3c4 \ub098\uce68\ubc18]</li> <li>[\uc99d\uad8c] \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548, \uae08\uc735\uc8fc \uac15\ud0c0 \u2026UBS \"\ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd\" [\uae40\ud604\uc11d\uc758 \uc6d4\uc2a4\ud2b8\ub9ac\ud2b8\ub098\uc6b0]</li> </ol>"},{"location":"reports/2026-02-28/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-02-28/#2026-02-28_1","title":"2026\ub144 02\uc6d4 28\uc77c \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ubd84\uc11d \ubcf4\uace0\uc11c","text":"<p>\uc791\uc131\uc790: \uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8</p> <p>\uc694\uc57d: 2026\ub144 2\uc6d4 28\uc77c \ud604\uc7ac, \uc2dc\uc7a5\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654, \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uac00\ub2a5\uc131, \uadf8\ub9ac\uace0 \uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\uc5d0 \ud63c\ub780\uc744 \uacaa\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub9cc\uc73c\ub85c \ubd84\uc11d\ud558\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \uc2ec\ub9ac\ub294 \ubd88\uc548\uc815\ud558\uba70 \ud22c\uc790\uc5d0 \uc2e0\uc911\ud55c \uc811\uadfc\uc774 \ud544\uc694\ud55c \uc2dc\uc810\uc785\ub2c8\ub2e4.</p>"},{"location":"reports/2026-02-28/#1","title":"1. \ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc","text":"<ul> <li>\uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c: \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9 \uad00\ub828 \ub274\uc2a4\uc5d0 \ub530\ub978 \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uac00 \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ubbf8\uce58\ub294 \uc9c1\uc811\uc801\uc778 \uc601\ud5a5\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc774\ub294 \ud5a5\ud6c4 \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc744 \ud655\ub300\uc2dc\ud0ac \uc218 \uc788\ub294 \uc8fc\uc694 \uc694\uc778\uc785\ub2c8\ub2e4.</li> <li>\uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc5d0 \ub300\ud55c \uc6b0\ub824\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ud2b9\ud788, \uae08\uc735\uc8fc \ud0c0\uaca9\uc740 \uc2dc\uc7a5\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ub354\uc6b1 \uc99d\ud3ed\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9: \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 \uc0c1\uc2b9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\ub294 \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud558\uba70, \uc18c\ube44 \uc2ec\ub9ac \uc704\ucd95 \ubc0f \uae30\uc5c5 \ube44\uc6a9 \uc99d\uac00\ub85c \uc774\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#2","title":"2. \ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2.1. \uac70\uc2dc \uacbd\uc81c \ubd84\uc11d:</p> <p>\ud604\uc7ac \ub274\uc2a4 \ub370\uc774\ud130\ub294 \uc81c\ud55c\uc801\uc774\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \ubd84\uc704\uae30\ub294 \ubd88\uc548\uc815\ud568\uc744 \ub098\ud0c0\ub0c5\ub2c8\ub2e4. \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9\uc73c\ub85c \uc778\ud55c \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub294 \uad6d\uc81c \uc720\uac00 \uc0c1\uc2b9\uc744 \uc57c\uae30\ud558\uace0, \uc774\ub294 \uc804 \uc138\uacc4\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788, 2026\ub144 \ucd08\ubd80\ud130 \uc9c0\uc18d\ub41c \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc740 \uae30\uc5c5\uc758 \uc0dd\uc0b0 \ube44\uc6a9 \uc99d\uac00\uc640 \uc18c\ube44\uc790\uc758 \uad6c\ub9e4\ub825 \uac10\uc18c\ub85c \uc774\uc5b4\uc838 \uacbd\uc81c \uc131\uc7a5\uc744 \ub454\ud654\uc2dc\ud0ac \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4.</p> <p>2.2. \uae08\uc735 \uc2dc\uc7a5 \ubd84\uc11d:</p> <ul> <li>\uc8fc\uc2dd \uc2dc\uc7a5: \ud55c\uad6d\uc804\ub825 \uc8fc\uac00 \ud558\ub77d\uc740 \uac1c\ubcc4 \uc885\ubaa9\uc758 \uc774\uc288\ub97c \ub118\uc5b4, \uc2dc\uc7a5 \uc804\ubc18\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ubc18\uc601\ud569\ub2c8\ub2e4. \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \ud22c\uc790 \uc2ec\ub9ac\ub97c \uc704\ucd95\uc2dc\ud0a4\uace0, \uc8fc\uc2dd \uc2dc\uc7a5\uc758 \ud558\ubc29 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5: \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc5d0 \ub300\ud55c \ubbfc\uac10\uc131\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\uac00 \uac15\ud654\ub418\uba74\uc11c \uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5\uc5d0\uc11c \uc790\uae08 \uc774\ud0c8\uc774 \ubc1c\uc0dd\ud55c \uac83\uc73c\ub85c \ud574\uc11d\ub429\ub2c8\ub2e4.</li> <li>\ucc44\uad8c \uc2dc\uc7a5: \uae08\ub9ac \uc778\uc0c1 \uac00\ub2a5\uc131\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c \ucc44\uad8c \uac00\uaca9\uc740 \ud558\ub77d \uc555\ub825\uc744 \ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\ub294 \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\ub97c \uc790\uadf9\ud558\uc5ec \ucc44\uad8c \uc218\uc694\ub97c \uc99d\uac00\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> <p>2.3. \ud22c\uc790 \uc804\ub7b5:</p> <ul> <li>\uc704\ud5d8 \uc790\uc0b0 \ube44\uc911 \ucd95\uc18c: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc640 \uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c\ub294 \uc8fc\uc2dd, \uc554\ud638\ud654\ud3d0 \ub4f1 \uc704\ud5d8 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ucd95\uc18c\ud558\uace0, \uc548\uc804 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ud655\ub300\ud558\ub294 \uac83\uc774 \ubc14\ub78c\uc9c1\ud569\ub2c8\ub2e4.</li> <li>\ud604\uae08 \ud655\ubcf4: \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc774 \ud655\ub300\ub420 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\ubbc0\ub85c, \ud604\uae08 \ud655\ubcf4\ub97c \ud1b5\ud574 \ud22c\uc790 \uae30\ud68c\ub97c \ud3ec\ucc29\ud558\uac70\ub098 \uc190\uc2e4\uc744 \ucd5c\uc18c\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uac00\uce58 \ud22c\uc790: \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc131\uc7a5 \uac00\ub2a5\uc131\uc774 \ub192\uc740 \uac00\uce58\uc8fc\uc5d0 \ud22c\uc790\ud558\ub294 \uc804\ub7b5\uc744 \uace0\ub824\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ubd84\uc0b0 \ud22c\uc790: \ud2b9\uc815 \uc790\uc0b0\uc5d0 \uc9d1\uc911 \ud22c\uc790\ud558\ub294 \uac83\uc744 \uc9c0\uc591\ud558\uace0, \ub2e4\uc591\ud55c \uc790\uc0b0\uc5d0 \ubd84\uc0b0 \ud22c\uc790\ud558\uc5ec \uc704\ud5d8\uc744 \ubd84\uc0b0\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9: '\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15\uc744 \ub0b8 \uc0ac\ub840\ucc98\ub7fc, \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc548\uc815\uc801\uc778 \uc218\uc775\uc744 \ucd94\uad6c\ud558\ub294 \ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9 \uc804\ub7b5\uc744 \uc801\uadf9\uc801\uc73c\ub85c \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#3","title":"3. \u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ul> <li>\ubbf8\uad6d \uc5f0\ubc29\uc900\ube44\uc81c\ub3c4(Fed)\uc758 \uae08\ub9ac \uacb0\uc815: \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uc5ec\ubd80\ub294 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c, Fed\uc758 \uae08\ub9ac \uacb0\uc815 \ubc0f \uad00\ub828 \ubc1c\uc5b8\uc5d0 \uc8fc\uc758\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\uc5d0 \ub530\ub978 \uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\uace0, \uacbd\uc81c \uc131\uc7a5\uc5d0 \ubd80\uc815\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c \uc9c0\uc18d\uc801\uc73c\ub85c \ubaa8\ub2c8\ud130\ub9c1\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ubbf8\uad6d-\uc774\ub780 \uad00\uacc4 \uc804\uac1c: \ubbf8\uad6d-\uc774\ub780 \uad00\uacc4\uc758 \ud5a5\ud6c4 \uc804\uac1c \uc591\uc0c1\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc758 \uc2ec\uac01\uc131\uc744 \uacb0\uc815\ud558\uace0, \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5 \ub3d9\ud5a5: 3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8\uc5d0 \ub300\ud55c \uad00\uc2ec\uc740 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ud5a5\ud6c4 \ub3d9\ud5a5\uc744 \uc8fc\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc0ac\ubaa8\ub300\ucd9c \uad00\ub828 \uae08\uc735\uae30\uad00 \uac74\uc804\uc131: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uc774 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc73c\ub85c \ud655\uc0b0\ub420 \uac00\ub2a5\uc131\uc5d0 \ub300\ube44\ud558\uc5ec \uad00\ub828 \uae08\uc735\uae30\uad00\uc758 \uac74\uc804\uc131\uc744 \uba74\ubc00\ud788 \uc0b4\ud3b4\uc57c \ud569\ub2c8\ub2e4.</li> </ul> <p>Disclaimer: \ubcf8 \ubcf4\uace0\uc11c\ub294 \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub97c \uae30\ubc18\uc73c\ub85c \uc791\uc131\ub418\uc5c8\uc73c\uba70, \ud22c\uc790 \uc790\ubb38\uc774 \uc544\ub2d9\ub2c8\ub2e4. \ud22c\uc790 \uacb0\uc815\uc740 \ubcf8\uc778\uc758 \ud310\ub2e8\uacfc \ucc45\uc784 \ud558\uc5d0 \uc2e0\uc911\ud558\uac8c \uc774\ub8e8\uc5b4\uc838\uc57c \ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-03-02)","text":""},{"location":"reports/2026-03-02/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \uc2e0\uc138\uacc4\ubc31\ud654\uc810, \ucd9c\uc0b0\uc728 \ubc18\ub4f1\uc5d0 '\uc720\ubaa8\ucc28 \ud398\uc5b4'\u2026\ucd5c\ub300 25% \ud61c\ud0dd</li> <li>[\uacbd\uc81c] \uc911\ub3d9 \uc804\uc7c1 \uc7a5\uae30\ud654 \ub550 \uc54c\ub8e8\ubbf8\ub284 \ub300\ub780?\u2026\uc720\ub7fd\u00b7\ubbf8\uad6d \uc218\uc785 20% \uc774\uc0c1 \ud754\ub4e4 [\uae40\uc8fc\uc644\uc758 \uc6d0\uc790\uc7ac \ud3ec\ucee4\uc2a4]</li> <li>[\uacbd\uc81c] \uc774\ub780 \uacf5\uaca9\uc5d0\ub3c4 \u7f8e\uc99d\uc2dc \ubcf4\ud569\uc138\u2026\uc9c0\uc0c1\uad70 \ud22c\uc785 \ub4f1 \uc7a5\uae30\ud654 \uac00\ub2a5\uc131 [\ubaa8\ub2dd\ube0c\ub9ac\ud551]</li> <li>[\uacbd\uc81c] '\ub450\ucac0\ucfe0' \uce74\ub2e4\uc774\ud504 \uc548\uc2ec\ud558\uace0 \uba39\uc5b4\ub3c4 \ub420\uae4c\u2026\uc218\uc785\uc2dd\ud488 \uc548\uc804\uc758 \ube44\ubc00 [\uc815\uc7ac\uc601\uc758 \uc2dd\ud488\uc758\uc57d \ud1ba\uc544\ubcf4\uae30]</li> <li>[\uacbd\uc81c] [\uce7c\ub7fc] \uae30\ud6c4\uc704\uae30 \ud574\uacb0 \uc704\ud574 \uc815\ucc45\uc694\uad6c \ucee4\uc838\uc57c</li> <li>[\uc99d\uad8c] \uc774\ub780 \uc0ac\ud0dc\uc5d0 \uad6d\uc81c\uc720\uac00 \uae09\ub4f1\u2026\ud558\ub098\u8b49 \"\ucd5c\uc545 \ub550 120\ub2ec\ub7ec\uae4c\uc9c0 \uc0c1\uc2b9 \uac00\ub2a5\"</li> <li>[\uc99d\uad8c] \"\uc0bc\uc131\uc804\uc790, \uc8fc\uac00 \uc0c1\uc2b9\uc5ec\ub825 \uc5ec\uc804\ud788 \ud06c\ub2e4\u2026\ubaa9\ud45c\uac00 \ub610 \uc0c1\ud5a5\"-\ud55c\uad6d</li> <li>[\uc99d\uad8c] \ub274\uc695\uc99d\uc2dc '\uc1fc\ud06c' \uc5c6\uc5c8\ub2e4\u2026\u7f8e\u00b7\uc774\ub780 \uc804\uc7c1\uc5d0\ub3c4 \ub098\uc2a4\ub2e5 \uac15\uc138</li> <li>[\uc99d\uad8c] \"\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4\"\u2026\uac1c\ubbf8\uad70\ub2e8, \ucf54\uc2a4\ud53c \uba71\uc0b4 \uc7a1\uace0 \uac04\ub2e4 [\ubd84\uc11d+]</li> <li>[\uc99d\uad8c] \uc911\ub3d9 \uccb4\ub958 \uad6d\ubbfc 1.7\ub9cc\uba85\u2026\uc815\ubd80, \uc721\ub85c \ub300\ud53c\uacc4\ud68d \uc218\ub9bd</li> </ol>"},{"location":"reports/2026-03-02/#_1","title":"\ud83d\udcca \uc2dc\uc7a5 \uc8fc\uc694 \uc9c0\ud45c (\uc804\uc77c \ub300\ube44)","text":"\uc9c0\ud45c\uba85 (\uae30\uc900\uc77c) \ud604\uc7ac\uac12 \uc804\uc77c\ub300\ube44 \uc784\uacc4\uac12 \uc0c1\ud0dc \uc7a5\ub2e8\uae30 \uae08\ub9ac\ucc28 (03/02) 0.58 -0.01 0.0 \u2705 \ub2ec\ub7ec \uc778\ub371\uc2a4 (02/27) 117.822 -0.082 120.0 \u2705 High Yield \uc2a4\ud504\ub808\ub4dc (02/28) 3.12 +0.02 4.0 \u2705 \uacf5\ud3ec \uc9c0\uc218 (VIX) (03/02) 21.44 +1.58 20.0 \u26a0\ufe0f"},{"location":"reports/2026-03-02/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-03-02/#_2","title":"\uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8 \ubcf4\uace0\uc11c","text":"<p>\uc791\uc131\uc77c: 2026\ub144 03\uc6d4 02\uc77c</p>"},{"location":"reports/2026-03-02/#_3","title":"\ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc","text":"<ol> <li>\uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc9c0\uc18d (Persistent Geopolitical Risk): \uc911\ub3d9 \uc9c0\uc5ed\uc758 \ubd88\uc548\uc815\uc131\uc774 \uc7a5\uae30\ud654 \uc870\uc9d0\uc744 \ubcf4\uc774\uba70 \uad6d\uc81c \uc720\uac00 \ubc0f \uc6d0\uc790\uc7ac \uc2dc\uc7a5\uc5d0 \uc9c0\uc18d\uc801\uc778 \ubcc0\ub3d9\uc131\uc744 \uc57c\uae30\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uacf5\uae09\ub9dd \uc804\ubc18\uc5d0 \uac78\uccd0 \ubd88\ud655\uc2e4\uc131\uc744 \uac00\uc911\uc2dc\ud0a4\ub294 \ud575\uc2ec \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uae30\uc220\uc8fc \uc911\uc2ec \uc2dc\uc7a5 \uacac\uc870 (Resilient Tech-led Market): \uc9c0\uc815\ud559\uc801 \ubd88\ud655\uc2e4\uc131 \uc18d\uc5d0\uc11c\ub3c4 \ubbf8\uad6d \ub098\uc2a4\ub2e5\uacfc \uac19\uc740 \uae30\uc220\uc8fc \uc911\uc2ec \uc2dc\uc7a5\uc774 \uacac\uc870\ud55c \ud750\ub984\uc744 \uc720\uc9c0\ud558\uace0 \uc788\uc73c\uba70, \uad6d\ub0b4 \uc0bc\uc131\uc804\uc790 \ub4f1 \ub300\ud615 \uae30\uc220 \uae30\uc5c5\uc5d0 \ub300\ud55c \uae0d\uc815\uc801\uc778 \uc804\ub9dd\uc774 \uc774\uc5b4\uc9c0\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \ud2b9\uc815 \uc139\ud130\uc758 \uc131\uc7a5 \ubaa8\uba58\ud140\uc774 \uac70\uc2dc\uc801 \ub9ac\uc2a4\ud06c\ub97c \uc0c1\uc1c4\ud558\ub294 \ubaa8\uc2b5\uc73c\ub85c \ud574\uc11d\ub429\ub2c8\ub2e4.</li> <li>\uc778\ud50c\ub808\uc774\uc158 \uc555\ub825 \uc7ac\ud655\uc778 (Reconfirmed Inflationary Pressure): \uc911\ub3d9 \uc0ac\ud0dc\ub85c \uc778\ud55c \uad6d\uc81c \uc720\uac00 \uae09\ub4f1 \uac00\ub2a5\uc131(\ucd5c\uc545 \uc2dc 120\ub2ec\ub7ec)\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc774 \uc5ec\uc804\ud788 \uae00\ub85c\ubc8c \uacbd\uc81c\uc758 \uc911\uc694\ud55c \ub3c4\uc804 \uacfc\uc81c\uc784\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \uc774\ub294 \uac01\uad6d \uc911\uc559\uc740\ud589\uc758 \ud1b5\ud654 \uc815\ucc45 \uacb0\uc815\uc5d0 \uc0c1\ub2f9\ud55c \uc601\ud5a5\uc744 \ubbf8\uce60 \uac83\uc73c\ub85c \uc608\uc0c1\ub429\ub2c8\ub2e4.</li> </ol>"},{"location":"reports/2026-03-02/#_4","title":"\ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2026\ub144 3\uc6d4 2\uc77c \ud604\uc7ac, \uae00\ub85c\ubc8c \uacbd\uc81c \ubc0f \uae08\uc735 \uc2dc\uc7a5\uc740 \uc9c0\uc815\ud559\uc801 \uae34\uc7a5\uacfc \uc774\ub85c \uc778\ud55c \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc774\ub77c\ub294 \ubcf5\ud569\uc801\uc778 \ub3c4\uc804 \uacfc\uc81c \uc18d\uc5d0\uc11c\ub3c4 \uae30\uc220\uc8fc\ub97c \uc911\uc2ec\uc73c\ub85c \ud55c \uc120\ubcc4\uc801 \uac15\uc138\ub97c \ubcf4\uc774\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \ud22c\uc790 \ud658\uacbd\uc758 \ubcf5\uc7a1\uc131\uc744 \ub354\uc6b1 \uc2ec\ud654\uc2dc\ud0a4\uba70, \uc815\uad50\ud55c \ubd84\uc11d\uacfc \uc2e0\uc911\ud55c \ud22c\uc790 \uc804\ub7b5 \uc218\ub9bd\uc744 \uc694\uad6c\ud569\ub2c8\ub2e4.</p> <p>1. \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc758 \uc7a5\uae30\ud654 \ubc0f \uc601\ud5a5: \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uc9c0\uc815\ud559\uc801 \uac08\ub4f1\uc740 \ub2e8\uae30\uc801 \uc774\uc288\ub97c \ub118\uc5b4 \uc7a5\uae30\uc801\uc778 \ubd88\ud655\uc2e4\uc131\uc73c\ub85c \uace0\ucc29\ud654\ub418\ub294 \uc591\uc0c1\uc785\ub2c8\ub2e4. \uc774\ub780 \uc0ac\ud0dc\uc640 \uac19\uc740 \uc77c\ub828\uc758 \uc0ac\uac74\ub4e4\uc774 \uad6d\uc81c \uc720\uac00\ub97c \ube44\ub86f\ud55c \uc54c\ub8e8\ubbf8\ub284 \ub4f1 \uc8fc\uc694 \uc6d0\uc790\uc7ac \uac00\uaca9\uc758 \ubcc0\ub3d9\uc131\uc744 \ud0a4\uc6b0\uace0 \uc788\uc73c\uba70, \uc774\ub294 \uae00\ub85c\ubc8c \uacf5\uae09\ub9dd \uc804\ubc18\uc5d0 \uac78\uccd0 \ube44\uc6a9 \uc0c1\uc2b9 \uc555\ub825\uc73c\ub85c \uc791\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \uc5d0\ub108\uc9c0 \ubc0f \uc0b0\uc5c5\uc7ac \uad00\ub828 \uae30\uc5c5\ub4e4\uc740 \uc6d0\uac00 \uc0c1\uc2b9\uacfc \uacf5\uae09 \ubd88\uc548\uc815\uc131 \uad00\ub9ac\uc758 \uc911\uc694\uc131\uc774 \ub354\uc6b1 \ucee4\uc9c8 \uac83\uc785\ub2c8\ub2e4. \uac01\uad6d \uc815\ubd80\uac00 \uc911\ub3d9 \uccb4\ub958 \uad6d\ubbfc \ub300\ud53c \uacc4\ud68d\uc744 \uc218\ub9bd\ud558\ub294 \uac83\uc740 \uc0ac\ud0dc\uc758 \uc2ec\uac01\uc131\uc744 \ubc18\uc601\ud558\uba70, \uc778\ub3c4\uc8fc\uc758\uc801 \uc704\uae30\ubfd0\ub9cc \uc544\ub2c8\ub77c \uacbd\uc81c\uc801 \ud30c\uae09 \ud6a8\uacfc\uc5d0 \ub300\ud55c \ub300\ube44\uac00 \ud544\uc694\ud568\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4.</p> <p>2. \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uacfc \ud1b5\ud654 \uc815\ucc45: \uad6d\uc81c \uc720\uac00\uc758 \uae09\ub4f1 \uac00\ub2a5\uc131\uc740 \uc778\ud50c\ub808\uc774\uc158 \uae30\ub300\uac10\uc744 \ub2e4\uc2dc \uc790\uadf9\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ucd5c\uc545\uc758 \uacbd\uc6b0 \uad6d\uc81c\uc720\uac00\uac00 120\ub2ec\ub7ec\uae4c\uc9c0 \uc0c1\uc2b9\ud560 \uc218 \uc788\ub2e4\ub294 \uc804\ub9dd\uc740, \uc774\ubbf8 \uc778\ud50c\ub808\uc774\uc158\uacfc \uc528\ub984\ud574 \uc628 \uac01\uad6d \uc911\uc559\uc740\ud589\ub4e4\uc5d0\uac8c \ucd94\uac00\uc801\uc778 \ud1b5\ud654 \uae34\ucd95 \ub610\ub294 \uc644\ud654 \uc815\ucc45 \uc9c0\uc5f0\uc774\ub77c\ub294 \uc5b4\ub824\uc6b4 \uc120\ud0dd\uc9c0\ub97c \uc548\uaca8\uc904 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uc804\ubc18\uc801\uc778 \uae08\ub9ac \uc218\uc900\uc5d0 \uc601\ud5a5\uc744 \ubbf8\uce58\uba70, \uae30\uc5c5\ub4e4\uc758 \uc790\uae08 \uc870\ub2ec \ube44\uc6a9\uacfc \uc18c\ube44\uc790\uc758 \uad6c\ub9e4\ub825\uc5d0 \uc9c1\uacb0\ub420 \uac83\uc785\ub2c8\ub2e4. \ud22c\uc790\uc790\ub4e4\uc740 \uc778\ud50c\ub808\uc774\uc158 \ud5e4\uc9c0 \uc218\ub2e8\uacfc \ub354\ubd88\uc5b4 \uae08\ub9ac \ubcc0\ub3d9\uc5d0 \uac15\ud55c \uae30\uc5c5\ub4e4\uc744 \uc8fc\ubaa9\ud574\uc57c \ud569\ub2c8\ub2e4.</p> <p>3. \uae30\uc220\uc8fc \uc911\uc2ec\uc758 \uc2dc\uc7a5 \uacac\uc870\uc138: \uc8fc\uc694 \uc9c0\uc815\ud559\uc801 \uc704\uae30 \uc18d\uc5d0\uc11c\ub3c4 \ubbf8\uad6d \uc99d\uc2dc, \ud2b9\ud788 \ub098\uc2a4\ub2e5\uc774 \uac15\uc138\ub97c \ubcf4\uc774\uace0 \uc0bc\uc131\uc804\uc790\uc640 \uac19\uc740 \uae30\uc220 \ub300\ud615\uc8fc\uc5d0 \ub300\ud55c \ubaa9\ud45c\uac00 \uc0c1\ud5a5 \uc870\uc815\uc774 \uc774\uc5b4\uc9c0\ub294 \uc810\uc740 \uc8fc\ubaa9\ud560 \ub9cc\ud569\ub2c8\ub2e4. \uc774\ub294 \u2460 \uae30\uc220 \ud601\uc2e0(\uc608: AI, \ubc18\ub3c4\uccb4)\uc774 \ucc3d\ucd9c\ud558\ub294 \uad6c\uc870\uc801 \uc131\uc7a5 \ub3d9\ub825\uc774 \uac70\uc2dc\uacbd\uc81c \ubd88\ud655\uc2e4\uc131\uc744 \uc0c1\uc1c4\ud560 \ub9cc\ud07c \uac15\ub825\ud558\uac70\ub098, \u2461 \uc2dc\uc7a5\uc774 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub97c \ud2b9\uc815 \uc139\ud130\uc5d0 \uad6d\ud55c\ub41c \ubb38\uc81c\ub85c \uc778\uc2dd\ud558\uace0 \uc788\uac70\ub098, \u2462 \ud48d\ubd80\ud55c \uc720\ub3d9\uc131\uc774 \uc5ec\uc804\ud788 \uc131\uc7a5\uc8fc\ub85c \uc720\uc785\ub418\uace0 \uc788\uc74c\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \uad6d\ub0b4 \ucf54\uc2a4\ud53c \uc2dc\uc7a5 \ub610\ud55c \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc758 \uc801\uadf9\uc801\uc778 \ucc38\uc5ec\ub85c \uacac\uc870\ud568\uc744 \uc720\uc9c0\ud558\uace0 \uc788\ub2e4\ub294 \ubd84\uc11d\uc740, \uc2dc\uc7a5\uc758 \uc720\ub3d9\uc131 \ud6a8\uacfc\uc640 \ub354\ubd88\uc5b4 \ud2b9\uc815 \uae30\uc5c5 \ubc0f \uc139\ud130\uc5d0 \ub300\ud55c \ud22c\uc790\uc790\ub4e4\uc758 \uac15\ud55c \uc2e0\ub8b0\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.</p> <p>4. \ud22c\uc790 \uc804\ub7b5: *   \ub9ac\uc2a4\ud06c \ubd84\uc0b0 \ubc0f \ud5e4\uc9c0: \uc9c0\uc815\ud559\uc801 \uc704\ud5d8\uacfc \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc774 \uc0c1\uc874\ud558\ub294 \ub9cc\ud07c, \ud3ec\ud2b8\ud3f4\ub9ac\uc624\uc758 \ubd84\uc0b0\uc740 \ud544\uc218\uc801\uc785\ub2c8\ub2e4. \uae08, \uc6d0\uc790\uc7ac \ub4f1 \uc778\ud50c\ub808\uc774\uc158 \ud5e4\uc9c0 \uc790\uc0b0\uc5d0 \ub300\ud55c \ubd80\ubd84\uc801\uc778 \ubc30\ubd84\uc744 \uace0\ub824\ud558\ub418, \ubcc0\ub3d9\uc131\uc774 \ud070 \ub9cc\ud07c \uc2e0\uc911\ud55c \uc811\uadfc\uc774 \uc694\uad6c\ub429\ub2c8\ub2e4. *   \ubc29\uc5b4\uc801 \uc131\uc7a5\uc8fc \uc120\ubcc4: \uae30\uc220 \uc139\ud130 \ub0b4\uc5d0\uc11c\ub3c4 \uc7ac\ubb34 \uac74\uc804\uc131\uc774 \uc6b0\uc218\ud558\uace0, \ub3c5\uc810\uc801\uc778 \uae30\uc220\ub825 \ubc0f \uacbd\uc7c1 \uc6b0\uc704\ub97c \ubc14\ud0d5\uc73c\ub85c \uc548\uc815\uc801\uc778 \ud604\uae08 \ud750\ub984\uc744 \ucc3d\ucd9c\ud558\ub294 \uae30\uc5c5\uc5d0 \uc9d1\uc911\ud574\uc57c \ud569\ub2c8\ub2e4. AI, \ubc18\ub3c4\uccb4 \ub4f1 \ubbf8\ub798 \uc131\uc7a5 \ub3d9\ub825\uc744 \ud655\ubcf4\ud55c \uae30\uc5c5\ub4e4\uc774 \uc720\ub9ac\ud560 \uac83\uc785\ub2c8\ub2e4. *   \uacf5\uae09\ub9dd \uc548\uc815\uc131 \uace0\ub824: \uc6d0\uc790\uc7ac \uac00\uaca9 \ubcc0\ub3d9 \ubc0f \uacf5\uae09\ub9dd \ubd88\uc548\uc5d0 \ub35c \ucde8\uc57d\ud558\uac70\ub098, \uc774\ub97c \uae30\ud68c\ub85c \uc0bc\uc744 \uc218 \uc788\ub294 \uae30\uc5c5(\uc608: \uc790\uccb4 \uacf5\uae09\ub9dd \ud655\ubcf4 \uae30\uc5c5, \ud544\uc218 \uc18c\ube44\uc7ac \uc911 \uac00\uaca9 \uc804\uac00\ub825\uc774 \ub192\uc740 \uae30\uc5c5)\uc5d0 \ub300\ud55c \uad00\uc2ec\uc774 \ud544\uc694\ud569\ub2c8\ub2e4. *   \uc5d0\ub108\uc9c0 \uc139\ud130: \uc720\uac00 \ubcc0\ub3d9\uc131 \ud655\ub300\ub85c \uc5d0\ub108\uc9c0 \uc139\ud130\ub294 \ub2e8\uae30\uc801\uc778 \ud2b8\ub808\uc774\ub529 \uae30\ud68c\ub97c \uc81c\uacf5\ud560 \uc218 \uc788\uc73c\ub098, \uc7a5\uae30\uc801\uc73c\ub85c\ub294 ESG \ud2b8\ub80c\ub4dc\uc640 \ub9de\ubb3c\ub824 \ubcf5\ud569\uc801\uc778 \uc2dc\uac01\uc73c\ub85c \uc811\uadfc\ud574\uc57c \ud569\ub2c8\ub2e4. *   \uad6d\ub0b4 \uc2dc\uc7a5: \uac1c\uc778 \ud22c\uc790\uc790 \ube44\uc911\uc774 \ub192\uc740 \uc2dc\uc7a5\uc758 \ud2b9\uc131\uc744 \uc774\ud574\ud558\uace0, \uc2dc\uc7a5\uc758 \uacfc\uc5f4 \uc5ec\ubd80\ub97c \uc8fc\uc2dc\ud558\uba70 \ub300\ud615 \uae30\uc220\uc8fc\uc640 \ub354\ubd88\uc5b4 \ub0b4\uc218 \uc18c\ube44\uc7ac \uc911\uc5d0\uc11c\ub3c4 \ucc28\ubcc4\ud654\ub41c \uacbd\uc7c1\ub825\uc744 \uac16\ucd98 \uae30\uc5c5(\uc608: \uc2e0\uc138\uacc4\ubc31\ud654\uc810\uc758 \uc720\ubaa8\ucc28 \ud398\uc5b4\uc640 \uac19\uc774 \ud2b9\uc815 \uc18c\ube44\uce35\uc744 \uacf5\ub7b5\ud558\ub294 \uc804\ub7b5\uc774 \uc131\uacf5\uc801\uc778 \uae30\uc5c5)\uc744 \uc120\ubcc4\ud558\ub294 \uac83\uc774 \uc911\uc694\ud569\ub2c8\ub2e4. \ucd9c\uc0b0\uc728 \ubc18\ub4f1\uc774\ub77c\ub294 \ub099\uad00\uc801 \uac00\uc815\ubcf4\ub2e4\ub294, \uace0\uc18c\ub4dd\uce35\uc744 \ud0c0\uac9f\uc73c\ub85c \ud55c \ud504\ub9ac\ubbf8\uc5c4 \uc2dc\uc7a5\uc758 \uc131\uc7a5 \uac00\ub2a5\uc131\uc744 \ub354 \ud604\uc2e4\uc801\uc73c\ub85c \ubd10\uc57c \ud560 \uac83\uc785\ub2c8\ub2e4. *   \uae30\ud6c4 \uc704\uae30 \ub300\uc751: '\uae30\ud6c4\uc704\uae30 \ud574\uacb0\uc744 \uc704\ud55c \uc815\ucc45 \uc694\uad6c'\ub294 \uc911\uc7a5\uae30\uc801\uc73c\ub85c \uc0b0\uc5c5 \uad6c\uc870 \uc804\ubc18\uc758 \ubcc0\ud654\ub97c \uac00\uc838\uc62c \ud575\uc2ec \ub3d9\uc778\uc785\ub2c8\ub2e4. ESG \uad00\ub828 \ud22c\uc790 \uae30\ud68c\uc640 \ub354\ubd88\uc5b4, \ud0c4\uc18c \uc911\ub9bd \uc804\ud658 \uacfc\uc815\uc5d0\uc11c \ubc1c\uc0dd\ud558\ub294 \uc0c8\ub85c\uc6b4 \uc0b0\uc5c5 \ubc0f \uae30\uc220 \ud22c\uc790\uc5d0 \uc8fc\ubaa9\ud574\uc57c \ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/#_5","title":"\u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ol> <li>\uc911\ub3d9 \uc9c0\uc5ed \uc9c0\uc815\ud559\uc801 \ub3d9\ud5a5: \uc774\ub780-\ubbf8\uad6d \uac04 \uae34\uc7a5 \uad00\uacc4, \uc774\uc2a4\ub77c\uc5d8-\ud558\ub9c8\uc2a4 \ubd84\uc7c1\uc758 \ud655\uc804 \ub610\ub294 \ud734\uc804 \ud611\uc0c1 \uc9c4\uc804 \uc5ec\ubd80, \uc8fc\uc694 \uc0b0\uc720\uad6d\ub4e4\uc758 \uc0dd\uc0b0\ub7c9 \uc870\uc808 \uc6c0\uc9c1\uc784 \ub4f1 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \ubaa8\ub4e0 \uc815\uce58\uc801, \uad70\uc0ac\uc801 \ub274\uc2a4\ub294 \uad6d\uc81c \uc720\uac00\uc640 \uc6d0\uc790\uc7ac \uc2dc\uc7a5\uc5d0 \uc989\uac01\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c \uba74\ubc00\ud788 \uc8fc\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uae00\ub85c\ubc8c \uc778\ud50c\ub808\uc774\uc158 \uc9c0\ud45c \ubc0f \uc911\uc559\uc740\ud589 \ud1b5\ud654\uc815\ucc45: \ubbf8\uad6d\uc758 \uc18c\ube44\uc790\ubb3c\uac00\uc9c0\uc218(CPI), \uc0dd\uc0b0\uc790\ubb3c\uac00\uc9c0\uc218(PPI), \uace0\uc6a9 \ubcf4\uace0\uc11c \ub4f1 \uc8fc\uc694 \uacbd\uc81c \uc9c0\ud45c \ubc1c\ud45c\uc640 \ud568\uaed8 \ubbf8\uad6d \uc5f0\ubc29\uc900\ube44\uc81c\ub3c4(Fed)\uc758 \uc5f0\ubc29\uacf5\uac1c\uc2dc\uc7a5\uc704\uc6d0\ud68c(FOMC) \ud68c\uc758 \uacb0\uacfc \ubc0f \uc758\uc7a5 \ubc1c\uc5b8\uc740 \uae08\ub9ac \ud5a5\ubc29\uacfc \uc2dc\uc7a5 \uc804\ubc18\uc758 \uc720\ub3d9\uc131\uc5d0 \uacb0\uc815\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uac83\uc785\ub2c8\ub2e4. \uc720\ub7fd\uc911\uc559\uc740\ud589(ECB), \ud55c\uad6d\uc740\ud589 \ub4f1 \uc8fc\uc694\uad6d \uc911\uc559\uc740\ud589\uc758 \uacb0\uc815 \ub610\ud55c \uc911\uc694\ud569\ub2c8\ub2e4.</li> <li>\uae00\ub85c\ubc8c \uacf5\uae09\ub9dd \uad00\ub828 \uc9c0\ud45c: \uc8fc\uc694 \ud56d\ub9cc\uc758 \uc6b4\uc784 \uc9c0\uc218, \uae00\ub85c\ubc8c \uc81c\uc870\uc5c5 \uad6c\ub9e4\uad00\ub9ac\uc790\uc9c0\uc218(PMI)\uc758 \uacf5\uae09\uc5c5\uccb4 \ubc30\uc1a1 \uc2dc\uac04 \uc9c0\uc218, \uc8fc\uc694 \uc6d0\uc790\uc7ac \uc7ac\uace0 \uc218\uc900 \ub4f1 \uacf5\uae09\ub9dd \ubcd1\ubaa9 \ud604\uc0c1 \uc644\ud654 \ub610\ub294 \uc2ec\ud654 \uc5ec\ubd80\ub97c \uac00\ub2a0\ud560 \uc218 \uc788\ub294 \uc9c0\ud45c\ub4e4\uc744 \uc9c0\uc18d\uc801\uc73c\ub85c \ubaa8\ub2c8\ud130\ub9c1\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc8fc\uc694 \uae30\uc5c5 \uc2e4\uc801 \ubc1c\ud45c: \ud2b9\ud788 \uae30\uc220 \uc139\ud130(\ubc18\ub3c4\uccb4, AI \uad00\ub828 \uae30\uc5c5) \ubc0f \uc5d0\ub108\uc9c0, \uc6d0\uc790\uc7ac \uad00\ub828 \ub300\ud615 \uae30\uc5c5\ub4e4\uc758 \ubd84\uae30\ubcc4 \uc2e4\uc801 \ubc1c\ud45c\ub294 \uc2dc\uc7a5\uc758 \uc804\ubc18\uc801\uc778 \ubc29\ud5a5\uc131\uacfc \ud2b9\uc815 \uc139\ud130\uc758 \uac74\uc804\uc131\uc744 \ud3c9\uac00\ud558\ub294 \uc911\uc694\ud55c \uc7a3\ub300\uac00 \ub420 \uac83\uc785\ub2c8\ub2e4.</li> </ol> <p>\ubcf8 \ubcf4\uace0\uc11c\ub294 2026\ub144 3\uc6d4 2\uc77c \ud604\uc7ac \uc785\uc218 \uac00\ub2a5\ud55c \uc815\ubcf4\ub97c \ubc14\ud0d5\uc73c\ub85c \uc791\uc131\ub418\uc5c8\uc73c\uba70, \uc2dc\uc7a5 \uc0c1\ud669\uc740 \uae09\ubcc0\ud560 \uc218 \uc788\uc73c\ubbc0\ub85c \ud22c\uc790 \uacb0\uc815 \uc2dc\uc5d0\ub294 \ucd94\uac00\uc801\uc778 \ubd84\uc11d\uacfc \uc804\ubb38\uac00\uc640\uc758 \uc0c1\ub2f4\uc774 \ud544\uc218\uc801\uc785\ub2c8\ub2e4.</p>"}]}