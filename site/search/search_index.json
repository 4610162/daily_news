{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/2026-02-28/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-02-28)","text":""},{"location":"reports/2026-02-28/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \"3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8 \uae30\ud68c\uc778\ub370\u2026\" 40\ub300 \uc9c1\uc7a5\uc778 \uba58\ubd95 \uc628 \uae4c\ub2ed [\ub3c8 \ubc84\ub294 \ubc95 \uc544\ub07c\ub294 \ubc95]</li> <li>[\uacbd\uc81c] \ud398\ub77c\ub9ac \ud0c0\ub358 \uc190\ud765\ubbfc, 1\uc5b5\uc9dc\ub9ac \u8eca \uc6b4\uc804 \ud3ec\ucc29\u2026\ubbf8\uad6d '\ub4e4\uc369'</li> <li>[\uacbd\uc81c] \u4f0a \ub9ac\ube59 \ube0c\ub79c\ub4dc '\uc2a4\ud14c\ud310\ud50c\ub77c\uc2a4\ud2b8', \uad6d\ub0b4 \ucf54\uc2a4\ud2b8\ucf54\uc5d0 \ud5ec\ud53c\uce74\ud2b8 \ucd9c\uc2dc</li> <li>[\uacbd\uc81c] \"\ub9e4\uc77c \ub2ec\ub838\ub354\ub2c8 \ud1b5\uc7a5\uc5d0 \ub3c8 \ub4e4\uc5b4\uc640\uc694\"\u2026\ub7ec\ub2dd\uc871\ub4e4 \ud658\ud638\ud55c \uc774\uc720</li> <li>[\uacbd\uc81c] \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 2\uc8fc \uc5f0\uc18d \uc0c1\uc2b9\u2026\uacbd\uc720\ub294 \ub2e4\uc74c \uc8fc\ub3c4 \uc624\ub97c \ub4ef</li> <li>[\uc99d\uad8c] \uae00\ub85c\ubc8c \ud070\uc190 4000\uc5b5 \uc4f8\uc5b4\ub2f4\ub354\ub2c8\u2026\ud55c \ub2ec \ub9cc\uc5d0 34% '\uae09\ub4f1' [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] [\uc18d\ubcf4] \ubbf8\uad6d \uc774\ub780 \uacf5\uaca9, \ube44\ud2b8\ucf54\uc778 4% \uc774\uc0c1 \uae09\ub77d, 6\ub9cc4000\ub2ec\ub7ec \ubd95\uad34</li> <li>[\uc99d\uad8c] \ucda9\uaca9 \uc18c\uc2dd\uc5d0 \uc798\ub098\uac00\ub358 \uc8fc\uac00 '\ud718\uccad'\u2026\ud55c\uad6d\uc804\ub825 \uac1c\ubbf8 \uc5b4\uca4c\ub098 [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] \uadf8\uc57c\ub9d0\ub85c '\ud55c \ub057 \ucc28\uc774'\u2026'\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15 \ub09c \uc774\uc720 \uc788\uc5c8\ub2e4 [\ubc15\uc8fc\uc5f0\uc758 \uc5ec\uc758\ub3c4 \ub098\uce68\ubc18]</li> <li>[\uc99d\uad8c] \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548, \uae08\uc735\uc8fc \uac15\ud0c0 \u2026UBS \"\ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd\" [\uae40\ud604\uc11d\uc758 \uc6d4\uc2a4\ud2b8\ub9ac\ud2b8\ub098\uc6b0]</li> </ol>"},{"location":"reports/2026-02-28/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-02-28/#2026-02-28_1","title":"2026\ub144 02\uc6d4 28\uc77c \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ubd84\uc11d \ubcf4\uace0\uc11c","text":"<p>\uc791\uc131\uc790: \uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8</p> <p>\uc694\uc57d: 2026\ub144 2\uc6d4 28\uc77c \ud604\uc7ac, \uc2dc\uc7a5\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654, \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uac00\ub2a5\uc131, \uadf8\ub9ac\uace0 \uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\uc5d0 \ud63c\ub780\uc744 \uacaa\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub9cc\uc73c\ub85c \ubd84\uc11d\ud558\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \uc2ec\ub9ac\ub294 \ubd88\uc548\uc815\ud558\uba70 \ud22c\uc790\uc5d0 \uc2e0\uc911\ud55c \uc811\uadfc\uc774 \ud544\uc694\ud55c \uc2dc\uc810\uc785\ub2c8\ub2e4.</p>"},{"location":"reports/2026-02-28/#1","title":"1. \ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc","text":"<ul> <li>\uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c: \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9 \uad00\ub828 \ub274\uc2a4\uc5d0 \ub530\ub978 \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uac00 \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ubbf8\uce58\ub294 \uc9c1\uc811\uc801\uc778 \uc601\ud5a5\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc774\ub294 \ud5a5\ud6c4 \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc744 \ud655\ub300\uc2dc\ud0ac \uc218 \uc788\ub294 \uc8fc\uc694 \uc694\uc778\uc785\ub2c8\ub2e4.</li> <li>\uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc5d0 \ub300\ud55c \uc6b0\ub824\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ud2b9\ud788, \uae08\uc735\uc8fc \ud0c0\uaca9\uc740 \uc2dc\uc7a5\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ub354\uc6b1 \uc99d\ud3ed\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9: \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 \uc0c1\uc2b9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\ub294 \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud558\uba70, \uc18c\ube44 \uc2ec\ub9ac \uc704\ucd95 \ubc0f \uae30\uc5c5 \ube44\uc6a9 \uc99d\uac00\ub85c \uc774\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#2","title":"2. \ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2.1. \uac70\uc2dc \uacbd\uc81c \ubd84\uc11d:</p> <p>\ud604\uc7ac \ub274\uc2a4 \ub370\uc774\ud130\ub294 \uc81c\ud55c\uc801\uc774\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \ubd84\uc704\uae30\ub294 \ubd88\uc548\uc815\ud568\uc744 \ub098\ud0c0\ub0c5\ub2c8\ub2e4. \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9\uc73c\ub85c \uc778\ud55c \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub294 \uad6d\uc81c \uc720\uac00 \uc0c1\uc2b9\uc744 \uc57c\uae30\ud558\uace0, \uc774\ub294 \uc804 \uc138\uacc4\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788, 2026\ub144 \ucd08\ubd80\ud130 \uc9c0\uc18d\ub41c \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc740 \uae30\uc5c5\uc758 \uc0dd\uc0b0 \ube44\uc6a9 \uc99d\uac00\uc640 \uc18c\ube44\uc790\uc758 \uad6c\ub9e4\ub825 \uac10\uc18c\ub85c \uc774\uc5b4\uc838 \uacbd\uc81c \uc131\uc7a5\uc744 \ub454\ud654\uc2dc\ud0ac \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4.</p> <p>2.2. \uae08\uc735 \uc2dc\uc7a5 \ubd84\uc11d:</p> <ul> <li>\uc8fc\uc2dd \uc2dc\uc7a5: \ud55c\uad6d\uc804\ub825 \uc8fc\uac00 \ud558\ub77d\uc740 \uac1c\ubcc4 \uc885\ubaa9\uc758 \uc774\uc288\ub97c \ub118\uc5b4, \uc2dc\uc7a5 \uc804\ubc18\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ubc18\uc601\ud569\ub2c8\ub2e4. \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \ud22c\uc790 \uc2ec\ub9ac\ub97c \uc704\ucd95\uc2dc\ud0a4\uace0, \uc8fc\uc2dd \uc2dc\uc7a5\uc758 \ud558\ubc29 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5: \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc5d0 \ub300\ud55c \ubbfc\uac10\uc131\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\uac00 \uac15\ud654\ub418\uba74\uc11c \uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5\uc5d0\uc11c \uc790\uae08 \uc774\ud0c8\uc774 \ubc1c\uc0dd\ud55c \uac83\uc73c\ub85c \ud574\uc11d\ub429\ub2c8\ub2e4.</li> <li>\ucc44\uad8c \uc2dc\uc7a5: \uae08\ub9ac \uc778\uc0c1 \uac00\ub2a5\uc131\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c \ucc44\uad8c \uac00\uaca9\uc740 \ud558\ub77d \uc555\ub825\uc744 \ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\ub294 \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\ub97c \uc790\uadf9\ud558\uc5ec \ucc44\uad8c \uc218\uc694\ub97c \uc99d\uac00\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> <p>2.3. \ud22c\uc790 \uc804\ub7b5:</p> <ul> <li>\uc704\ud5d8 \uc790\uc0b0 \ube44\uc911 \ucd95\uc18c: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc640 \uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c\ub294 \uc8fc\uc2dd, \uc554\ud638\ud654\ud3d0 \ub4f1 \uc704\ud5d8 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ucd95\uc18c\ud558\uace0, \uc548\uc804 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ud655\ub300\ud558\ub294 \uac83\uc774 \ubc14\ub78c\uc9c1\ud569\ub2c8\ub2e4.</li> <li>\ud604\uae08 \ud655\ubcf4: \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc774 \ud655\ub300\ub420 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\ubbc0\ub85c, \ud604\uae08 \ud655\ubcf4\ub97c \ud1b5\ud574 \ud22c\uc790 \uae30\ud68c\ub97c \ud3ec\ucc29\ud558\uac70\ub098 \uc190\uc2e4\uc744 \ucd5c\uc18c\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uac00\uce58 \ud22c\uc790: \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc131\uc7a5 \uac00\ub2a5\uc131\uc774 \ub192\uc740 \uac00\uce58\uc8fc\uc5d0 \ud22c\uc790\ud558\ub294 \uc804\ub7b5\uc744 \uace0\ub824\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ubd84\uc0b0 \ud22c\uc790: \ud2b9\uc815 \uc790\uc0b0\uc5d0 \uc9d1\uc911 \ud22c\uc790\ud558\ub294 \uac83\uc744 \uc9c0\uc591\ud558\uace0, \ub2e4\uc591\ud55c \uc790\uc0b0\uc5d0 \ubd84\uc0b0 \ud22c\uc790\ud558\uc5ec \uc704\ud5d8\uc744 \ubd84\uc0b0\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9: '\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15\uc744 \ub0b8 \uc0ac\ub840\ucc98\ub7fc, \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc548\uc815\uc801\uc778 \uc218\uc775\uc744 \ucd94\uad6c\ud558\ub294 \ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9 \uc804\ub7b5\uc744 \uc801\uadf9\uc801\uc73c\ub85c \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#3","title":"3. \u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ul> <li>\ubbf8\uad6d \uc5f0\ubc29\uc900\ube44\uc81c\ub3c4(Fed)\uc758 \uae08\ub9ac \uacb0\uc815: \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uc5ec\ubd80\ub294 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c, Fed\uc758 \uae08\ub9ac \uacb0\uc815 \ubc0f \uad00\ub828 \ubc1c\uc5b8\uc5d0 \uc8fc\uc758\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\uc5d0 \ub530\ub978 \uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\uace0, \uacbd\uc81c \uc131\uc7a5\uc5d0 \ubd80\uc815\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c \uc9c0\uc18d\uc801\uc73c\ub85c \ubaa8\ub2c8\ud130\ub9c1\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ubbf8\uad6d-\uc774\ub780 \uad00\uacc4 \uc804\uac1c: \ubbf8\uad6d-\uc774\ub780 \uad00\uacc4\uc758 \ud5a5\ud6c4 \uc804\uac1c \uc591\uc0c1\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc758 \uc2ec\uac01\uc131\uc744 \uacb0\uc815\ud558\uace0, \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5 \ub3d9\ud5a5: 3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8\uc5d0 \ub300\ud55c \uad00\uc2ec\uc740 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ud5a5\ud6c4 \ub3d9\ud5a5\uc744 \uc8fc\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc0ac\ubaa8\ub300\ucd9c \uad00\ub828 \uae08\uc735\uae30\uad00 \uac74\uc804\uc131: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uc774 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc73c\ub85c \ud655\uc0b0\ub420 \uac00\ub2a5\uc131\uc5d0 \ub300\ube44\ud558\uc5ec \uad00\ub828 \uae08\uc735\uae30\uad00\uc758 \uac74\uc804\uc131\uc744 \uba74\ubc00\ud788 \uc0b4\ud3b4\uc57c \ud569\ub2c8\ub2e4.</li> </ul> <p>Disclaimer: \ubcf8 \ubcf4\uace0\uc11c\ub294 \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub97c \uae30\ubc18\uc73c\ub85c \uc791\uc131\ub418\uc5c8\uc73c\uba70, \ud22c\uc790 \uc790\ubb38\uc774 \uc544\ub2d9\ub2c8\ub2e4. \ud22c\uc790 \uacb0\uc815\uc740 \ubcf8\uc778\uc758 \ud310\ub2e8\uacfc \ucc45\uc784 \ud558\uc5d0 \uc2e0\uc911\ud558\uac8c \uc774\ub8e8\uc5b4\uc838\uc57c \ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-03-02)","text":""},{"location":"reports/2026-03-02/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \uc774\ub780\uacf5\uc2b5 3\uc77c\ucc28 \u7f8e\uc99d\uc2dc \ub099\ud3ed \uc904\uc5ec\u2026\ubc29\uc0b0\uc8fc \uc77c\uc81c\ud788 \uc0c1\uc2b9</li> <li>[\uacbd\uc81c] \uc5d4\ube44\ub514\uc544,\uad11\uc790\uacf5\ud559\uc5c5\uccb4 \ub8e8\uba58\ud140,\ucf54\ud788\ub7f0\ud2b8\uc5d0 5.8\uc870\uc6d0 \ud22c\uc790</li> <li>[\uacbd\uc81c] \uce74\ud0c0\ub974, \uc774\ub780 \ub4dc\ub860 \uacf5\uaca9\uc5d0 \uc138\uacc4\ucd5c\ub300 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8</li> <li>[\uacbd\uc81c] \uc720\uac00 \uc804\ub9dd \"100\ub2ec\ub7ec \uc774\uc0c1\" vs \"\ub2f9\ubd84\uac04 80\ub2ec\ub7ec\ub300 \uac70\ub798\"</li> <li>[\uacbd\uc81c] \uc774\ub780 \"\ud558\uba54\ub124\uc774 \ud6c4\uc784\uc790 \ud558\ub8e8 \uc774\ud2c0\ub0b4 \uc120\ucd9c\"</li> <li>[\uc99d\uad8c] \"\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4\"\u2026\uac1c\ubbf8\uad70\ub2e8, \ucf54\uc2a4\ud53c \uba71\uc0b4 \uc7a1\uace0 \uac04\ub2e4 [\ubd84\uc11d+]</li> <li>[\uc99d\uad8c] \uc911\ub3d9 \uccb4\ub958\uc790 1.7\ub9cc\uba85\u2026\uc815\ubd80, \uc721\ub85c \ub300\ud53c\uacc4\ud68d \uc218\ub9bd</li> <li>[\uc99d\uad8c] \uae40\ubcd1\uc8fc \uc790\ud0dd \ub2f4\ubcf4\ub85c\u2026MBK, \ud648\ud50c\ub7ec\uc2a4 \uc218\ud608\uc790\uae08 1000\uc5b5 \ub9c8\ub828</li> <li>[\uc99d\uad8c] '\uc624\uc77c \uc1fc\ud06c' \ub2e5\uce58\ub098\u2026\ub2db\ucf00\uc774, \uac1c\uc7a5 \ud558\uc790\ub9c8\uc790 2.7% \ud558\ub77d</li> <li>[\uc99d\uad8c] 2000\ub144 \uc774\ud6c4 \uc5ec\uc12f \ubc88 '\uc911\ub3d9 \ub9ac\uc2a4\ud06c'\u2026\ucf54\uc2a4\ud53c \ud55c\ub2ec \ub4a4 \ubaa8\ub450 \ud68c\ubcf5\ud588\ub2e4</li> </ol>"},{"location":"reports/2026-03-02/#_1","title":"\ud83d\udcca \uc2dc\uc7a5 \uc8fc\uc694 \uc9c0\ud45c (\uc804\uc77c \ub300\ube44)","text":"\uc9c0\ud45c\uba85 (\uae30\uc900\uc77c) \ud604\uc7ac\uac12 \uc804\uc77c\ub300\ube44 \uc784\uacc4\uac12 \uc0c1\ud0dc \uc7a5\ub2e8\uae30 \uae08\ub9ac\ucc28 (02/27) 0.59 -0.01 0.0 \u2705 \ub2ec\ub7ec \uc778\ub371\uc2a4 (02/20) 117.992 -0.244 120.0 \u2705 High Yield \uc2a4\ud504\ub808\ub4dc (02/26) 2.98 +0.04 4.0 \u2705 \uacf5\ud3ec \uc9c0\uc218 (VIX) (03/02) 21.6 +1.74 20.0 \u26a0\ufe0f"},{"location":"reports/2026-03-02/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-03-02/#2026-03-02_1","title":"\uacbd\uc81c \ubc0f \uae08\uc735 \ubcf4\uace0\uc11c (\uae30\uc900 \uc2dc\uc810: 2026\ub144 03\uc6d4 02\uc77c)","text":""},{"location":"reports/2026-03-02/#_2","title":"\ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc","text":"<ol> <li>\uc911\ub3d9 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c (Middle East Geopolitical Risk): \uc774\ub780 \uacf5\uc2b5 3\uc77c\ucc28, \uce74\ud0c0\ub974 LNG \uc2dc\uc124 \uc911\ub2e8, \uc774\ub780 \ud558\uba54\ub124\uc774 \ud6c4\uc784\uc790 \uc120\ucd9c \uc784\ubc15, \uc911\ub3d9 \uccb4\ub958\uc790 \ub300\ud53c \uacc4\ud68d \ub4f1 \ubcf5\ud569\uc801\uc778 \uc694\uc778\uc774 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \ubd88\ud655\uc2e4\uc131\uc744 \uadf9\ub300\ud654\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 \uc2dc\uc7a5 \ubd88\uc548\uc815\uc131 \uc2ec\ud654 (Deepened Energy Market Instability): \uce74\ud0c0\ub974\ubc1c LNG \uc0dd\uc0b0 \uc911\ub2e8 \uc18c\uc2dd\uacfc \uc720\uac00 100\ub2ec\ub7ec \uc774\uc0c1 \uc804\ub9dd \ub300\ub450\ub294 \uae00\ub85c\ubc8c \uc5d0\ub108\uc9c0 \uacf5\uae09\ub9dd\uc5d0 \uc2ec\uac01\ud55c \uc555\ubc15\uc744 \uac00\ud558\uba70 \uc778\ud50c\ub808\uc774\uc158 \uc6b0\ub824\ub97c \uc7ac\uc810\ud654\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4.</li> <li>\uae30\uc220 \ud601\uc2e0 \ud22c\uc790 \uc9c0\uc18d (Continued Tech Innovation Investment): \uc5d4\ube44\ub514\uc544\uc758 5.8\uc870 \uc6d0 \uaddc\ubaa8 \uad11\uc790\uacf5\ud559 \ud22c\uc790 \uc18c\uc2dd\uc740 \uc9c0\uc815\ud559\uc801 \ubd88\ud655\uc2e4\uc131 \uc18d\uc5d0\uc11c\ub3c4 \ucca8\ub2e8 \uae30\uc220 \ubd84\uc57c\uc758 \uc7a5\uae30\uc801\uc778 \uc131\uc7a5 \ub3d9\ub825\uc774 \uc5ec\uc804\ud788 \uc720\ud6a8\ud568\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4.</li> </ol>"},{"location":"reports/2026-03-02/#_3","title":"\ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2026\ub144 3\uc6d4 2\uc77c \ud604\uc7ac, \uae00\ub85c\ubc8c \uae08\uc735\uc2dc\uc7a5\uc740 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uae09\uaca9\ud55c \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\ub85c \uc778\ud55c \uac15\ub825\ud55c \ucda9\uaca9\ud30c\uc5d0 \uc9c1\uba74\ud574 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub780\uc758 \uacf5\uc2b5 3\uc77c\ucc28 \uc18c\uc2dd\uacfc \ud568\uaed8 \uce74\ud0c0\ub974\uc758 \uc138\uacc4 \ucd5c\ub300 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8\uc740 \uc5d0\ub108\uc9c0 \uacf5\uae09\ub9dd\uc5d0 \uc989\uac01\uc801\uc778 \ud0c0\uaca9\uc744 \uc8fc\uba70, \ub2db\ucf00\uc774 \uc9c0\uc218\uc758 \ud558\ub77d\uc5d0\uc11c \ubcfc \uc218 \uc788\ub4ef\uc774 \uc544\uc2dc\uc544 \uc2dc\uc7a5\uc744 \uc911\uc2ec\uc73c\ub85c \uc704\ud5d8 \ud68c\ud53c \uc2ec\ub9ac\uac00 \ud655\uc0b0\ub418\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub3d9\uc2dc\uc5d0 \uc720\uac00 100\ub2ec\ub7ec \uc774\uc0c1 \uc804\ub9dd\uc774 \uc81c\uae30\ub418\uba74\uc11c '\uc624\uc77c \uc1fc\ud06c' \uac00\ub2a5\uc131\ub9c8\uc800 \uc5b8\uae09\ub418\uace0 \uc788\uc5b4, \uc774\ub294 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825 \uac00\uc911 \ubc0f \uae00\ub85c\ubc8c \uacbd\uae30 \ub454\ud654 \uc6b0\ub824\ub97c \uc99d\ud3ed\uc2dc\ud0a4\ub294 \ud575\uc2ec \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud560 \uac83\uc785\ub2c8\ub2e4.</p> <p>\ud558\uc9c0\ub9cc \uc2dc\uc7a5\uc758 \ubc18\uc751\uc740 \ub2e4\uc18c \ubcf5\ud569\uc801\uc785\ub2c8\ub2e4. \ubbf8\uad6d \uc99d\uc2dc\uc758 \ub099\ud3ed \ucd95\uc18c\uc640 \ubc29\uc0b0\uc8fc\uc758 \uc77c\uc81c \uc0c1\uc2b9\uc740 \ud2b9\uc815 \uc139\ud130\ub85c\uc758 \uc790\uae08 \uc774\ub3d9\uacfc \ud568\uaed8 \uc77c\ubd80 \uc2dc\uc7a5 \ucc38\uc5ec\uc790\ub4e4\uc758 \ud68c\ubcf5\ub825\uc5d0 \ub300\ud55c \uae30\ub300\ub97c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \ub610\ud55c, \"\ucf54\uc2a4\ud53c \ud55c \ub2ec \ub4a4 \ubaa8\ub450 \ud68c\ubcf5\ud588\ub2e4\"\ub294 \uacfc\uac70 \uc911\ub3d9 \ub9ac\uc2a4\ud06c \uc0ac\ub840 \ubd84\uc11d\uacfc \"\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4\"\ub294 \uad6d\ub0b4 \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc758 \uc131\uc219\ud55c \ud0dc\ub3c4 \uc5b8\uae09\uc740 \ud55c\uad6d \uc2dc\uc7a5\uc758 \uc7a0\uc7ac\uc801 \ud68c\ubcf5 \ud0c4\ub825\uc131\uc744 \uc2dc\uc0ac\ud558\ub294 \ub300\ubaa9\uc785\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc5ed\uc0ac\uc801 \ubd84\uc11d\uc740 \ud604\uc7ac\uc758 \ud328\ub2c9\ubcf4\ub2e4\ub294 \uc2e0\uc911\ud55c \uc811\uadfc\uc744 \uc720\ub3c4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ud2b9\ud788 \uc8fc\ubaa9\ud560 \uc810\uc740 \uc9c0\uc815\ud559\uc801 \ubd88\uc548\uc815 \uc18d\uc5d0\uc11c\ub3c4 \uc5d4\ube44\ub514\uc544\uc640 \uac19\uc740 \uc120\ub3c4 \uae30\uc5c5\uc774 \uad11\uc790\uacf5\ud559 \ubd84\uc57c\uc5d0 \ub300\uaddc\ubaa8 \ud22c\uc790\ub97c \ub2e8\ud589\ud588\ub2e4\ub294 \uc0ac\uc2e4\uc785\ub2c8\ub2e4. \uc774\ub294 AI, \uace0\uc131\ub2a5 \ucef4\ud4e8\ud305 \ub4f1 4\ucc28 \uc0b0\uc5c5\ud601\uba85\uc758 \ud575\uc2ec \uae30\uc220 \ubd84\uc57c\uc5d0 \ub300\ud55c \uc7a5\uae30\uc801\uc778 \uc131\uc7a5 \ube44\uc804\uc774 \uc5ec\uc804\ud788 \uacac\uace0\ud568\uc744 \ubcf4\uc5ec\uc8fc\uba70, \uc2dc\uc7a5\uc758 \ub2e8\uae30\uc801\uc778 \ubcc0\ub3d9\uc131 \uc18d\uc5d0\uc11c\ub3c4 \uad6c\uc870\uc801 \uc131\uc7a5 \ub3d9\ub825\uc744 \uac00\uc9c4 \uae30\uc5c5\uc5d0 \ub300\ud55c \ud22c\uc790\ub294 \uc9c0\uc18d\ub420 \uac83\uc784\uc744 \uc554\uc2dc\ud569\ub2c8\ub2e4.</p> <p>\ud22c\uc790 \uc804\ub7b5:</p> <ol> <li> <p>\ub2e8\uae30\uc801 \uc704\ud5d8 \uad00\ub9ac \ubc0f \uc720\ub3d9\uc131 \ud655\ubcf4:</p> <ul> <li>\ud604\uae08 \ube44\uc911 \ud655\ub300 \ub610\ub294 \ubc29\uc5b4\uc801 \uc790\uc0b0 \uc120\ud638: \uc911\ub3d9 \uc0c1\ud669\uc758 \ubd88\ud655\uc2e4\uc131\uc774 \ud574\uc18c\ub420 \ub54c\uae4c\uc9c0 \ud604\uae08 \ube44\uc911\uc744 \ub192\uc774\uac70\ub098, \uc548\uc804\uc790\uc0b0(\uc608: \ubbf8\uad6d \ub2ec\ub7ec, \uae08)\uc73c\ub85c\uc758 \ubd84\uc0b0 \ud22c\uc790\ub97c \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ubc29\uc0b0\uc8fc \ubc0f \uc77c\ubd80 \uc5d0\ub108\uc9c0 \uad00\ub828\uc8fc \uc120\ubcc4\uc801 \uc811\uadfc: \uc9c0\uc815\ud559\uc801 \uae34\uc7a5 \uace0\uc870\uc5d0 \ub530\ub978 \uc9c1\uc811\uc801\uc778 \uc218\ud61c\uac00 \uc608\uc0c1\ub418\ub294 \ubc29\uc0b0 \uc139\ud130\ub294 \ub2e8\uae30\uc801\uc778 \ubaa8\uba58\ud140\uc744 \uac00\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc5d0\ub108\uc9c0 \uc139\ud130\ub294 \uc720\uac00 \uc0c1\uc2b9 \uc555\ub825\uc5d0 \ud798\uc785\uc5b4 \uae0d\uc815\uc801\uc77c \uc218 \uc788\uc73c\ub098, \ub192\uc740 \ubcc0\ub3d9\uc131\uc744 \uac10\uc548\ud558\uc5ec \ud380\ub354\uba58\ud138\uc774 \uacac\uace0\ud55c \ub300\ud615 \uae30\uc5c5 \uc704\uc8fc\ub85c \uc2e0\uc911\ud558\uac8c \uc811\uadfc\ud574\uc57c \ud569\ub2c8\ub2e4. LNG \uacf5\uae09\ub9dd \ubd88\uc548\uc815\uc740 \uad00\ub828 \uae30\uc5c5\uc5d0 \uae30\ud68c\uac00 \ub420 \uc218 \uc788\uc73c\ub098, \uc0dd\uc0b0 \uc911\ub2e8 \ub9ac\uc2a4\ud06c \ub610\ud55c \uc0c1\uc874\ud569\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uc911\uc7a5\uae30\uc801 \uad00\uc810\uc758 \uae30\ud68c \ubaa8\uc0c9:</p> <ul> <li>\uae30\uc220 \ud601\uc2e0 \uc139\ud130\uc758 \uc870\uc815 \uc2dc \ub9e4\uc218 \uae30\ud68c \ud65c\uc6a9: \uc5d4\ube44\ub514\uc544\uc758 \ud22c\uc790\uc5d0\uc11c \ubcf4\ub4ef\uc774, \uc778\uacf5\uc9c0\ub2a5, \ubc18\ub3c4\uccb4, \uad11\uc790\uacf5\ud559 \ub4f1 \ubbf8\ub798 \uc131\uc7a5 \ub3d9\ub825\uc744 \uac00\uc9c4 \uae30\uc220 \uc139\ud130\ub294 \ub2e8\uae30\uc801\uc778 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub85c \uc778\ud55c \uc2dc\uc7a5 \uc870\uc815 \uc2dc \ub9e4\ub825\uc801\uc778 \ub9e4\uc218 \uae30\ud68c\ub97c \uc81c\uacf5\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uae30\uc5c5\ub4e4\uc740 \uc7a5\uae30\uc801\uc778 \uba54\uac00\ud2b8\ub80c\ub4dc\uc5d0 \uae30\ubc18\ud558\uace0 \uc788\uc5b4, \ub2e8\uae30 \ucda9\uaca9 \uc774\ud6c4\uc758 \ud68c\ubcf5\ub825\uc774 \ub192\uc744 \uac83\uc73c\ub85c \uc608\uc0c1\ub429\ub2c8\ub2e4.</li> <li>\ubd84\uc0b0 \ud22c\uc790 \ubc0f \ud3ec\ud2b8\ud3f4\ub9ac\uc624 \ub2e4\uac01\ud654: \ud2b9\uc815 \uc9c0\uc5ed\uc774\ub098 \uc790\uc0b0\uad70\uc5d0 \ub300\ud55c \ud3b8\uc911\uc744 \ud53c\ud558\uace0, \uae00\ub85c\ubc8c \ubd84\uc0b0 \ud22c\uc790\ub97c \ud1b5\ud574 \ub9ac\uc2a4\ud06c\ub97c \uc644\ud654\ud574\uc57c \ud569\ub2c8\ub2e4. \ud2b9\ud788 \uc911\ub3d9 \uc758\uc874\ub3c4\uac00 \ub0ae\uc740 \uc2e0\ud765\uad6d\uc774\ub098 \uc120\uc9c4\uad6d \uc2dc\uc7a5 \ub0b4\uc5d0\uc11c\ub3c4 \ub3c5\uc790\uc801\uc778 \uc131\uc7a5 \ub3d9\ub825\uc744 \uac00\uc9c4 \uae30\uc5c5\ub4e4\uc744 \ubc1c\uad74\ud558\ub294 \ub178\ub825\uc774 \ud544\uc694\ud569\ub2c8\ub2e4.</li> <li>\uc778\ud50c\ub808\uc774\uc158 \ud5e4\uc9c0 \uc804\ub7b5 \uace0\ub824: \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc774 \uc7a5\uae30\ud654\ub420 \uacbd\uc6b0, \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc740 \ub354\uc6b1 \uac00\uc911\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc5d0 \ub300\ube44\ud558\uc5ec \uc6d0\uc790\uc7ac, \ubd80\ub3d9\uc0b0 \uad00\ub828 \uc790\uc0b0 \ub610\ub294 \ubb3c\uac00\uc5f0\ub3d9\ucc44\uad8c(TIPS) \ub4f1 \uc778\ud50c\ub808\uc774\uc158 \ud5e4\uc9c0 \ud6a8\uacfc\ub97c \uae30\ub300\ud560 \uc218 \uc788\ub294 \uc790\uc0b0\uc5d0 \ub300\ud55c \ubc30\ubd84\uc744 \uace0\ub824\ud560 \ud544\uc694\uac00 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\ud55c\uad6d \uc2dc\uc7a5 \ud2b9\uc774\uc810 \uace0\ub824:</p> <ul> <li>'\uc5ed\uc0ac\uc801 \ud68c\ubcf5 \ud0c4\ub825\uc131'\uacfc '\uac1c\ubbf8\uad70\ub2e8'\uc758 \uc5ed\ud560: \uacfc\uac70 \uc911\ub3d9 \ub9ac\uc2a4\ud06c \uc774\ud6c4 \ucf54\uc2a4\ud53c\uc758 \ud68c\ubcf5 \uc0ac\ub840\uc640 \uad6d\ub0b4 \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc758 \ud22c\uc790 \uc2ec\ub9ac \ubcc0\ud654\ub294 \uc2dc\uc7a5\uc758 \uae09\ub77d\uc5d0 \ub300\ud55c \uacfc\ub3c4\ud55c \uacf5\ud3ec\ub97c \uacbd\uacc4\ud558\uac8c \ud569\ub2c8\ub2e4. \ub300\uaddc\ubaa8 \uc870\uc815 \uc2dc\uc5d0\ub294 \ud380\ub354\uba58\ud138\uc774 \uc6b0\ub7c9\ud55c \uad6d\ub0b4 \ub300\ud45c \uae30\uc5c5\ub4e4\uc744 \uc800\uac00\uc5d0 \ub9e4\uc218\ud560 \uc218 \uc788\ub294 \uae30\ud68c\uac00 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> </li> </ol> <p>\uacb0\ub860\uc801\uc73c\ub85c, \ud604\uc7ac \uc2dc\uc7a5\uc740 \ub2e8\uae30\uc801\uc778 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc640 \uc5d0\ub108\uc9c0 \uc2dc\uc7a5 \ubd88\uc548\uc815\uc131\uc73c\ub85c \uc778\ud55c \ub192\uc740 \ubcc0\ub3d9\uc131\uc5d0 \uc9c1\uba74\ud574 \uc788\uc2b5\ub2c8\ub2e4. \ud22c\uc790\uc790\ub4e4\uc740 \ucca0\uc800\ud55c \uc704\ud5d8 \uad00\ub9ac\uc640 \ud568\uaed8, \uc911\uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uae30\uc220 \ud601\uc2e0 \ubc0f \uad6c\uc870\uc801 \uc131\uc7a5\uc744 \uc774\ub044\ub294 \uae30\uc5c5\ub4e4\uc5d0 \ub300\ud55c \uae30\ud68c\ub97c \ud0d0\uc0c9\ud558\ub294 \uc804\ub7b5\uc801 \uc811\uadfc\uc774 \uc694\uad6c\ub429\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/#_4","title":"\u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ol> <li> <p>\uc911\ub3d9 \uc9c0\uc815\ud559\uc801 \uc804\uac1c:</p> <ul> <li>\uc774\ub780-\uc774\uc2a4\ub77c\uc5d8/\ubbf8\uad6d \uac04\uc758 \ucd94\uac00 \uad70\uc0ac \ud589\ub3d9 \ub610\ub294 \ud655\uc804 \uc5ec\ubd80: \uc0c1\ud669 \uc545\ud654 \uc2dc \uc2dc\uc7a5 \ubd88\uc548\uc815\uc131\uc774 \uadf9\ub300\ud654\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc774\ub780 \ucd5c\uace0\uc9c0\ub3c4\uc790 \ud558\uba54\ub124\uc774 \ud6c4\uc784\uc790 \uc120\ucd9c \uacb0\uacfc \ubc0f \uc0c8 \uc9c0\ub3c4\ubd80\uc758 \uc815\ucc45 \ubc29\ud5a5: \uc774\ub780 \ub0b4\ubd80 \uc815\uc138\uc758 \uc548\uc815\ud654 \ub610\ub294 \ucd94\uac00\uc801\uc778 \ubd88\uc548 \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc911\ub3d9 \uc9c0\uc5ed \uc8fc\uc694\uad6d\ub4e4\uc758 \ubc18\uc751 \ubc0f \uc678\uad50\uc801 \ub178\ub825: \uc0ac\uc6b0\ub514\uc544\ub77c\ube44\uc544, UAE \ub4f1 \uc8fc\ubcc0\uad6d\ub4e4\uc758 \uac1c\uc785 \uc5ec\ubd80 \ubc0f \uad6d\uc81c \uc0ac\ud68c\uc758 \uc911\uc7ac \ub178\ub825\uc740 \uc0c1\ud669 \uc9c4\uc815\uc5d0 \uc911\uc694\ud55c \ubcc0\uc218\uc785\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uc5d0\ub108\uc9c0 \uc2dc\uc7a5 \uc9c0\ud45c:</p> <ul> <li>\uce74\ud0c0\ub974 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc7ac\uac1c \uc2dc\uc810 \ubc0f \uc0dd\uc0b0\ub7c9 \ud68c\ubcf5 \ucd94\uc774: \uae00\ub85c\ubc8c \uac00\uc2a4 \uacf5\uae09 \uc548\uc815\ud654\uc5d0 \uacb0\uc815\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce69\ub2c8\ub2e4.</li> <li>\uad6d\uc81c \uc720\uac00 (WTI, Brent) \ubcc0\ub3d9\uc131: 100\ub2ec\ub7ec \ub3cc\ud30c \uc5ec\ubd80\uc640 \uc9c0\uc18d\uc131\uc774 \uc778\ud50c\ub808\uc774\uc158 \ubc0f \uacbd\uae30 \ub454\ud654 \uc6b0\ub824\ub97c \uc2ec\ud654\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>OPEC+ \uc815\ub840 \ud68c\uc758 \ubc0f \uc8fc\uc694 \uc0b0\uc720\uad6d\ub4e4\uc758 \uc6d0\uc720 \uc0dd\uc0b0\ub7c9 \uc870\uc808 \uc5ec\ubd80: \uc720\uac00 \uc548\uc815\ud654\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5\uc774 \ud07d\ub2c8\ub2e4.</li> <li>IEA (\uad6d\uc81c\uc5d0\ub108\uc9c0\uae30\uad6c) \ubc0f EIA (\ubbf8\uad6d \uc5d0\ub108\uc9c0\uc815\ubcf4\uccad)\uc758 \uc6d4\uac04 \ubcf4\uace0\uc11c: \uae00\ub85c\ubc8c \uc5d0\ub108\uc9c0 \uc218\uae09 \uc804\ub9dd \uc5c5\ub370\uc774\ud2b8\ub294 \uc911\uc694\ud569\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uae00\ub85c\ubc8c \uac70\uc2dc \uacbd\uc81c \uc9c0\ud45c:</p> <ul> <li>\uc8fc\uc694\uad6d \uc18c\ube44\uc790\ubb3c\uac00\uc9c0\uc218 (CPI) \ubc0f \uc0dd\uc0b0\uc790\ubb3c\uac00\uc9c0\uc218 (PPI): \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc774 \uc804\ubc18\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158\uc73c\ub85c \uc804\uc774\ub418\ub294\uc9c0 \uc8fc\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc8fc\uc694 \uc911\uc559\uc740\ud589 (Fed, ECB, BoK \ub4f1)\uc758 \ud1b5\ud654\uc815\ucc45 \ud68c\uc758 \ubc0f \uc131\uba85: \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825 \uc99d\uac00 \uc2dc \uae08\ub9ac \uc778\ud558 \uae30\ub300\uac00 \ud6c4\ud1f4\ud558\uac70\ub098 \ucd94\uac00 \uae34\ucd95 \uac00\ub2a5\uc131\uc774 \uc81c\uae30\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uae00\ub85c\ubc8c \uc81c\uc870\uc5c5 PMI \ubc0f \uacbd\uae30 \uc120\ud589 \uc9c0\uc218: \uc5d0\ub108\uc9c0 \uc1fc\ud06c\uac00 \uc2e4\ubb3c \uacbd\uc81c\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5\uc744 \ud30c\uc545\ud558\ub294 \ub370 \uc911\uc694\ud569\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uae30\uc5c5 \uc2e4\uc801 \ubc0f \ud22c\uc790 \ub3d9\ud5a5:</p> <ul> <li>\ubc29\uc0b0, \uc5d0\ub108\uc9c0, \uae30\uc220 \uc139\ud130 \uc8fc\uc694 \uae30\uc5c5\ub4e4\uc758 \uc2e4\uc801 \ubc1c\ud45c: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \ubc0f \uc5d0\ub108\uc9c0 \uac00\uaca9 \ubcc0\ub3d9\uc774 \uae30\uc5c5 \uc218\uc775\uc131\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5\uc744 \uc9c1\uc811\uc801\uc73c\ub85c \ud655\uc778\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d4\ube44\ub514\uc544 \ub4f1 \uc120\ub3c4 \uae30\uc220 \uae30\uc5c5\ub4e4\uc758 \ucd94\uac00 \ud22c\uc790 \ub610\ub294 M&amp;A \uc18c\uc2dd: \uc7a5\uae30\uc801\uc778 \uc0b0\uc5c5 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220 \ud601\uc2e0 \uc18d\ub3c4\ub97c \uac00\ub2a0\ud558\ub294 \uc9c0\ud45c\uac00 \ub429\ub2c8\ub2e4.</li> </ul> </li> </ol>"}]}