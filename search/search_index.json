{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/2026-02-28/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-02-28)","text":""},{"location":"reports/2026-02-28/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \"3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8 \uae30\ud68c\uc778\ub370\u2026\" 40\ub300 \uc9c1\uc7a5\uc778 \uba58\ubd95 \uc628 \uae4c\ub2ed [\ub3c8 \ubc84\ub294 \ubc95 \uc544\ub07c\ub294 \ubc95]</li> <li>[\uacbd\uc81c] \ud398\ub77c\ub9ac \ud0c0\ub358 \uc190\ud765\ubbfc, 1\uc5b5\uc9dc\ub9ac \u8eca \uc6b4\uc804 \ud3ec\ucc29\u2026\ubbf8\uad6d '\ub4e4\uc369'</li> <li>[\uacbd\uc81c] \u4f0a \ub9ac\ube59 \ube0c\ub79c\ub4dc '\uc2a4\ud14c\ud310\ud50c\ub77c\uc2a4\ud2b8', \uad6d\ub0b4 \ucf54\uc2a4\ud2b8\ucf54\uc5d0 \ud5ec\ud53c\uce74\ud2b8 \ucd9c\uc2dc</li> <li>[\uacbd\uc81c] \"\ub9e4\uc77c \ub2ec\ub838\ub354\ub2c8 \ud1b5\uc7a5\uc5d0 \ub3c8 \ub4e4\uc5b4\uc640\uc694\"\u2026\ub7ec\ub2dd\uc871\ub4e4 \ud658\ud638\ud55c \uc774\uc720</li> <li>[\uacbd\uc81c] \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 2\uc8fc \uc5f0\uc18d \uc0c1\uc2b9\u2026\uacbd\uc720\ub294 \ub2e4\uc74c \uc8fc\ub3c4 \uc624\ub97c \ub4ef</li> <li>[\uc99d\uad8c] \uae00\ub85c\ubc8c \ud070\uc190 4000\uc5b5 \uc4f8\uc5b4\ub2f4\ub354\ub2c8\u2026\ud55c \ub2ec \ub9cc\uc5d0 34% '\uae09\ub4f1' [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] [\uc18d\ubcf4] \ubbf8\uad6d \uc774\ub780 \uacf5\uaca9, \ube44\ud2b8\ucf54\uc778 4% \uc774\uc0c1 \uae09\ub77d, 6\ub9cc4000\ub2ec\ub7ec \ubd95\uad34</li> <li>[\uc99d\uad8c] \ucda9\uaca9 \uc18c\uc2dd\uc5d0 \uc798\ub098\uac00\ub358 \uc8fc\uac00 '\ud718\uccad'\u2026\ud55c\uad6d\uc804\ub825 \uac1c\ubbf8 \uc5b4\uca4c\ub098 [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] \uadf8\uc57c\ub9d0\ub85c '\ud55c \ub057 \ucc28\uc774'\u2026'\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15 \ub09c \uc774\uc720 \uc788\uc5c8\ub2e4 [\ubc15\uc8fc\uc5f0\uc758 \uc5ec\uc758\ub3c4 \ub098\uce68\ubc18]</li> <li>[\uc99d\uad8c] \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548, \uae08\uc735\uc8fc \uac15\ud0c0 \u2026UBS \"\ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd\" [\uae40\ud604\uc11d\uc758 \uc6d4\uc2a4\ud2b8\ub9ac\ud2b8\ub098\uc6b0]</li> </ol>"},{"location":"reports/2026-02-28/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-02-28/#2026-02-28_1","title":"2026\ub144 02\uc6d4 28\uc77c \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ubd84\uc11d \ubcf4\uace0\uc11c","text":"<p>\uc791\uc131\uc790: \uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8</p> <p>\uc694\uc57d: 2026\ub144 2\uc6d4 28\uc77c \ud604\uc7ac, \uc2dc\uc7a5\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654, \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uac00\ub2a5\uc131, \uadf8\ub9ac\uace0 \uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\uc5d0 \ud63c\ub780\uc744 \uacaa\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub9cc\uc73c\ub85c \ubd84\uc11d\ud558\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \uc2ec\ub9ac\ub294 \ubd88\uc548\uc815\ud558\uba70 \ud22c\uc790\uc5d0 \uc2e0\uc911\ud55c \uc811\uadfc\uc774 \ud544\uc694\ud55c \uc2dc\uc810\uc785\ub2c8\ub2e4.</p>"},{"location":"reports/2026-02-28/#1","title":"1. \ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc","text":"<ul> <li>\uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c: \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9 \uad00\ub828 \ub274\uc2a4\uc5d0 \ub530\ub978 \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uac00 \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ubbf8\uce58\ub294 \uc9c1\uc811\uc801\uc778 \uc601\ud5a5\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc774\ub294 \ud5a5\ud6c4 \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc744 \ud655\ub300\uc2dc\ud0ac \uc218 \uc788\ub294 \uc8fc\uc694 \uc694\uc778\uc785\ub2c8\ub2e4.</li> <li>\uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc5d0 \ub300\ud55c \uc6b0\ub824\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ud2b9\ud788, \uae08\uc735\uc8fc \ud0c0\uaca9\uc740 \uc2dc\uc7a5\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ub354\uc6b1 \uc99d\ud3ed\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9: \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 \uc0c1\uc2b9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\ub294 \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud558\uba70, \uc18c\ube44 \uc2ec\ub9ac \uc704\ucd95 \ubc0f \uae30\uc5c5 \ube44\uc6a9 \uc99d\uac00\ub85c \uc774\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#2","title":"2. \ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2.1. \uac70\uc2dc \uacbd\uc81c \ubd84\uc11d:</p> <p>\ud604\uc7ac \ub274\uc2a4 \ub370\uc774\ud130\ub294 \uc81c\ud55c\uc801\uc774\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \ubd84\uc704\uae30\ub294 \ubd88\uc548\uc815\ud568\uc744 \ub098\ud0c0\ub0c5\ub2c8\ub2e4. \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9\uc73c\ub85c \uc778\ud55c \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub294 \uad6d\uc81c \uc720\uac00 \uc0c1\uc2b9\uc744 \uc57c\uae30\ud558\uace0, \uc774\ub294 \uc804 \uc138\uacc4\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788, 2026\ub144 \ucd08\ubd80\ud130 \uc9c0\uc18d\ub41c \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc740 \uae30\uc5c5\uc758 \uc0dd\uc0b0 \ube44\uc6a9 \uc99d\uac00\uc640 \uc18c\ube44\uc790\uc758 \uad6c\ub9e4\ub825 \uac10\uc18c\ub85c \uc774\uc5b4\uc838 \uacbd\uc81c \uc131\uc7a5\uc744 \ub454\ud654\uc2dc\ud0ac \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4.</p> <p>2.2. \uae08\uc735 \uc2dc\uc7a5 \ubd84\uc11d:</p> <ul> <li>\uc8fc\uc2dd \uc2dc\uc7a5: \ud55c\uad6d\uc804\ub825 \uc8fc\uac00 \ud558\ub77d\uc740 \uac1c\ubcc4 \uc885\ubaa9\uc758 \uc774\uc288\ub97c \ub118\uc5b4, \uc2dc\uc7a5 \uc804\ubc18\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ubc18\uc601\ud569\ub2c8\ub2e4. \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \ud22c\uc790 \uc2ec\ub9ac\ub97c \uc704\ucd95\uc2dc\ud0a4\uace0, \uc8fc\uc2dd \uc2dc\uc7a5\uc758 \ud558\ubc29 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5: \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc5d0 \ub300\ud55c \ubbfc\uac10\uc131\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\uac00 \uac15\ud654\ub418\uba74\uc11c \uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5\uc5d0\uc11c \uc790\uae08 \uc774\ud0c8\uc774 \ubc1c\uc0dd\ud55c \uac83\uc73c\ub85c \ud574\uc11d\ub429\ub2c8\ub2e4.</li> <li>\ucc44\uad8c \uc2dc\uc7a5: \uae08\ub9ac \uc778\uc0c1 \uac00\ub2a5\uc131\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c \ucc44\uad8c \uac00\uaca9\uc740 \ud558\ub77d \uc555\ub825\uc744 \ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\ub294 \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\ub97c \uc790\uadf9\ud558\uc5ec \ucc44\uad8c \uc218\uc694\ub97c \uc99d\uac00\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> <p>2.3. \ud22c\uc790 \uc804\ub7b5:</p> <ul> <li>\uc704\ud5d8 \uc790\uc0b0 \ube44\uc911 \ucd95\uc18c: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc640 \uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c\ub294 \uc8fc\uc2dd, \uc554\ud638\ud654\ud3d0 \ub4f1 \uc704\ud5d8 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ucd95\uc18c\ud558\uace0, \uc548\uc804 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ud655\ub300\ud558\ub294 \uac83\uc774 \ubc14\ub78c\uc9c1\ud569\ub2c8\ub2e4.</li> <li>\ud604\uae08 \ud655\ubcf4: \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc774 \ud655\ub300\ub420 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\ubbc0\ub85c, \ud604\uae08 \ud655\ubcf4\ub97c \ud1b5\ud574 \ud22c\uc790 \uae30\ud68c\ub97c \ud3ec\ucc29\ud558\uac70\ub098 \uc190\uc2e4\uc744 \ucd5c\uc18c\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uac00\uce58 \ud22c\uc790: \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc131\uc7a5 \uac00\ub2a5\uc131\uc774 \ub192\uc740 \uac00\uce58\uc8fc\uc5d0 \ud22c\uc790\ud558\ub294 \uc804\ub7b5\uc744 \uace0\ub824\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ubd84\uc0b0 \ud22c\uc790: \ud2b9\uc815 \uc790\uc0b0\uc5d0 \uc9d1\uc911 \ud22c\uc790\ud558\ub294 \uac83\uc744 \uc9c0\uc591\ud558\uace0, \ub2e4\uc591\ud55c \uc790\uc0b0\uc5d0 \ubd84\uc0b0 \ud22c\uc790\ud558\uc5ec \uc704\ud5d8\uc744 \ubd84\uc0b0\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9: '\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15\uc744 \ub0b8 \uc0ac\ub840\ucc98\ub7fc, \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc548\uc815\uc801\uc778 \uc218\uc775\uc744 \ucd94\uad6c\ud558\ub294 \ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9 \uc804\ub7b5\uc744 \uc801\uadf9\uc801\uc73c\ub85c \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#3","title":"3. \u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ul> <li>\ubbf8\uad6d \uc5f0\ubc29\uc900\ube44\uc81c\ub3c4(Fed)\uc758 \uae08\ub9ac \uacb0\uc815: \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uc5ec\ubd80\ub294 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c, Fed\uc758 \uae08\ub9ac \uacb0\uc815 \ubc0f \uad00\ub828 \ubc1c\uc5b8\uc5d0 \uc8fc\uc758\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\uc5d0 \ub530\ub978 \uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\uace0, \uacbd\uc81c \uc131\uc7a5\uc5d0 \ubd80\uc815\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c \uc9c0\uc18d\uc801\uc73c\ub85c \ubaa8\ub2c8\ud130\ub9c1\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ubbf8\uad6d-\uc774\ub780 \uad00\uacc4 \uc804\uac1c: \ubbf8\uad6d-\uc774\ub780 \uad00\uacc4\uc758 \ud5a5\ud6c4 \uc804\uac1c \uc591\uc0c1\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc758 \uc2ec\uac01\uc131\uc744 \uacb0\uc815\ud558\uace0, \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5 \ub3d9\ud5a5: 3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8\uc5d0 \ub300\ud55c \uad00\uc2ec\uc740 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ud5a5\ud6c4 \ub3d9\ud5a5\uc744 \uc8fc\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc0ac\ubaa8\ub300\ucd9c \uad00\ub828 \uae08\uc735\uae30\uad00 \uac74\uc804\uc131: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uc774 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc73c\ub85c \ud655\uc0b0\ub420 \uac00\ub2a5\uc131\uc5d0 \ub300\ube44\ud558\uc5ec \uad00\ub828 \uae08\uc735\uae30\uad00\uc758 \uac74\uc804\uc131\uc744 \uba74\ubc00\ud788 \uc0b4\ud3b4\uc57c \ud569\ub2c8\ub2e4.</li> </ul> <p>Disclaimer: \ubcf8 \ubcf4\uace0\uc11c\ub294 \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub97c \uae30\ubc18\uc73c\ub85c \uc791\uc131\ub418\uc5c8\uc73c\uba70, \ud22c\uc790 \uc790\ubb38\uc774 \uc544\ub2d9\ub2c8\ub2e4. \ud22c\uc790 \uacb0\uc815\uc740 \ubcf8\uc778\uc758 \ud310\ub2e8\uacfc \ucc45\uc784 \ud558\uc5d0 \uc2e0\uc911\ud558\uac8c \uc774\ub8e8\uc5b4\uc838\uc57c \ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-03-02)","text":""},{"location":"reports/2026-03-02/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \uc774\ub780\uacf5\uc2b5 3\uc77c\ucc28 \u7f8e\uc99d\uc2dc \ub099\ud3ed \uc904\uc5ec\u2026\ubc29\uc0b0\uc8fc \uc77c\uc81c\ud788 \uc0c1\uc2b9</li> <li>[\uacbd\uc81c] \uc5d4\ube44\ub514\uc544,\uad11\uc790\uacf5\ud559\uc5c5\uccb4 \ub8e8\uba58\ud140,\ucf54\ud788\ub7f0\ud2b8\uc5d0 5.8\uc870\uc6d0 \ud22c\uc790</li> <li>[\uacbd\uc81c] \uce74\ud0c0\ub974, \uc774\ub780 \ub4dc\ub860 \uacf5\uaca9\uc5d0 \uc138\uacc4\ucd5c\ub300 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8</li> <li>[\uacbd\uc81c] \uc720\uac00 \uc804\ub9dd \"100\ub2ec\ub7ec \uc774\uc0c1\" vs \"\ub2f9\ubd84\uac04 80\ub2ec\ub7ec\ub300 \uac70\ub798\"</li> <li>[\uacbd\uc81c] \uc774\ub780 \"\ud558\uba54\ub124\uc774 \ud6c4\uc784\uc790 \ud558\ub8e8 \uc774\ud2c0\ub0b4 \uc120\ucd9c\"</li> <li>[\uc99d\uad8c] \"\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4\"\u2026\uac1c\ubbf8\uad70\ub2e8, \ucf54\uc2a4\ud53c \uba71\uc0b4 \uc7a1\uace0 \uac04\ub2e4 [\ubd84\uc11d+]</li> <li>[\uc99d\uad8c] \uc911\ub3d9 \uccb4\ub958\uc790 1.7\ub9cc\uba85\u2026\uc815\ubd80, \uc721\ub85c \ub300\ud53c\uacc4\ud68d \uc218\ub9bd</li> <li>[\uc99d\uad8c] \uae40\ubcd1\uc8fc \uc790\ud0dd \ub2f4\ubcf4\ub85c\u2026MBK, \ud648\ud50c\ub7ec\uc2a4 \uc218\ud608\uc790\uae08 1000\uc5b5 \ub9c8\ub828</li> <li>[\uc99d\uad8c] '\uc624\uc77c \uc1fc\ud06c' \ub2e5\uce58\ub098\u2026\ub2db\ucf00\uc774, \uac1c\uc7a5 \ud558\uc790\ub9c8\uc790 2.7% \ud558\ub77d</li> <li>[\uc99d\uad8c] 2000\ub144 \uc774\ud6c4 \uc5ec\uc12f \ubc88 '\uc911\ub3d9 \ub9ac\uc2a4\ud06c'\u2026\ucf54\uc2a4\ud53c \ud55c\ub2ec \ub4a4 \ubaa8\ub450 \ud68c\ubcf5\ud588\ub2e4</li> </ol>"},{"location":"reports/2026-03-02/#_1","title":"\ud83d\udcca \uc2dc\uc7a5 \uc8fc\uc694 \uc9c0\ud45c (\uc804\uc77c \ub300\ube44)","text":"\uc9c0\ud45c\uba85 (\uae30\uc900\uc77c) \ud604\uc7ac\uac12 \uc804\uc77c\ub300\ube44 \uc784\uacc4\uac12 \uc0c1\ud0dc \uc7a5\ub2e8\uae30 \uae08\ub9ac\ucc28 (02/27) 0.59 -0.01 0.0 \u2705 \ub2ec\ub7ec \uc778\ub371\uc2a4 (02/20) 117.992 -0.244 120.0 \u2705 High Yield \uc2a4\ud504\ub808\ub4dc (02/26) 2.98 +0.04 4.0 \u2705 \uacf5\ud3ec \uc9c0\uc218 (VIX) (03/02) 21.5 +1.64 20.0 \u26a0\ufe0f"},{"location":"reports/2026-03-02/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-03-02/#2026-03-02_1","title":"\ud83d\udcca \uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8 \ubcf4\uace0\uc11c (\uae30\uc900 \uc2dc\uc810: 2026\ub144 03\uc6d4 02\uc77c)","text":"<p>\uc874\uacbd\ud558\ub294 \ud22c\uc790\uc790 \uc5ec\ub7ec\ubd84,</p> <p>2026\ub144 3\uc6d4 2\uc77c \ud604\uc7ac, \uae00\ub85c\ubc8c \uacbd\uc81c \ubc0f \uae08\uc735 \uc2dc\uc7a5\uc740 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uc9c0\uc815\ud559\uc801 \ubd88\uc548\uc815\uc131 \uc2ec\ud654\uc640 \ud568\uaed8 \uae30\uc220 \uc139\ud130\uc758 \uc804\ub7b5\uc801 \ud22c\uc790\uac00 \uacf5\uc874\ud558\ub294 \ubcf5\ud569\uc801\uc778 \ud658\uacbd\uc5d0 \uc9c1\uba74\ud574 \uc788\uc2b5\ub2c8\ub2e4. \ubcf8 \ubcf4\uace0\uc11c\ub294 \ub2f9\uc77c \uc8fc\uc694 \ub274\uc2a4 \ub370\uc774\ud130\ub97c \uae30\ubc18\uc73c\ub85c \uc2ec\uce35\uc801\uc778 \ubd84\uc11d\uacfc \ud568\uaed8 \ud5a5\ud6c4 \ud22c\uc790 \uc804\ub7b5\uc744 \uc81c\uc2dc\ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/#1-3","title":"1. \ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc (3\uac1c)","text":"<ol> <li>\uc911\ub3d9 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654: \uc774\ub780 \uacf5\uc2b5 \ubc0f \uce74\ud0c0\ub974 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8 \ub4f1 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uad70\uc0ac\uc801 \uae34\uc7a5 \uace0\uc870\uac00 \ud575\uc2ec \uc704\ud5d8 \uc694\uc778\uc73c\ub85c \ubd80\uc0c1\ud588\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uc5d0\ub108\uc9c0 \uacf5\uae09\ub9dd \ubd88\uc548\uc815 \ubc0f \uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9\uc131 \ud655\ub300\ub85c \uc774\uc5b4\uc9c0\uace0 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 \uc2dc\uc7a5 \ubd88\uc548\uc815\uc131 \uc99d\ub300: \uc774\ub780\uacfc \uce74\ud0c0\ub974 \ubc1c \uc774\uc288\ub85c \uc778\ud574 \uc720\uac00 100\ub2ec\ub7ec \uc774\uc0c1 \uc804\ub9dd\uacfc 80\ub2ec\ub7ec\ub300 \uc720\uc9c0 \uc804\ub9dd\uc774 \ud33d\ud33d\ud788 \ub9de\uc11c\uba70 \uc5d0\ub108\uc9c0 \uac00\uaca9\uc758 \ubd88\ud655\uc2e4\uc131\uc774 \uadf9\ub300\ud654\ub418\uace0 \uc788\uc2b5\ub2c8\ub2e4. LNG \uc2dc\uc124 \uc911\ub2e8\uc740 \ucc9c\uc5f0\uac00\uc2a4 \uc2dc\uc7a5\uc5d0\ub3c4 \uc9c1\uc811\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uac83\uc73c\ub85c \uc608\uc0c1\ub429\ub2c8\ub2e4.</li> <li>AI \uc778\ud504\ub77c \ud22c\uc790 \uac00\uc18d\ud654: \uc5d4\ube44\ub514\uc544\uc758 \uad11\uc790\uacf5\ud559\uc5c5\uccb4 \ub300\uaddc\ubaa8 \ud22c\uc790\ub294 \uc778\uacf5\uc9c0\ub2a5(AI) \uc2dc\ub300\uc758 \ud575\uc2ec \uc778\ud504\ub77c\uc778 \uace0\uc131\ub2a5 \ub370\uc774\ud130 \uc804\uc1a1 \uae30\uc220\uc758 \uc911\uc694\uc131\uc744 \uc7ac\ud655\uc778\ud558\uba70, \uae30\uc220 \uc139\ud130 \ub0b4 AI \uad00\ub828 \uc131\uc7a5 \ub3d9\ub825\uc774 \uc5ec\uc804\ud788 \uac15\ub825\ud568\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4.</li> </ol>"},{"location":"reports/2026-03-02/#2","title":"2. \ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5 (\uc2ec\ub3c4 \uc788\uac8c)","text":"<p>\uac00. \uae00\ub85c\ubc8c \uc9c0\uc815\ud559\uc801 \ubd88\uc548\uc815\uacfc \uc5d0\ub108\uc9c0 \uc2dc\uc7a5\uc758 \ud30c\uae09 \ud6a8\uacfc</p> <p>\ud604\uc7ac \uac00\uc7a5 \uc2dc\uae09\ud558\uac8c \uc8fc\ubaa9\ud574\uc57c \ud560 \uc0ac\uc548\uc740 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uace0\uc870\uc785\ub2c8\ub2e4. \uc774\ub780 \uacf5\uc2b5 3\uc77c\ucc28\uc640 \uce74\ud0c0\ub974\uc758 \uc138\uacc4 \ucd5c\ub300 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8 \uc18c\uc2dd\uc740 \uad6d\uc81c \uc5d0\ub108\uc9c0 \uc2dc\uc7a5\uc5d0 \uc2ec\uac01\ud55c \uacf5\uae09 \ucc28\uc9c8 \uc6b0\ub824\ub97c \ubd88\uc5b4\ub123\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \ub2e8\uc21c\ud55c \uc720\uac00 \uc0c1\uc2b9 \uc555\ub825\uc744 \ub118\uc5b4, \uc804 \uc138\uacc4\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub2e4\uc2dc \uace0\uc870\uc2dc\ud0a4\uace0 \uc2a4\ud0dc\uadf8\ud50c\ub808\uc774\uc158(Stagflation) \uc704\ud5d8\uc744 \uc99d\ub300\uc2dc\ud0ac \uc218 \uc788\ub294 \uc7a0\uc7ac\ub825\uc744 \uac00\uc9c0\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788, \"\uc624\uc77c \uc1fc\ud06c\" \uac00\ub2a5\uc131\uc5d0 \ub300\ud55c \uc2dc\uc7a5\uc758 \uacbd\uacc4\uc2ec\uc740 \ub2db\ucf00\uc774 \uc9c0\uc218\uc758 \uae09\ub77d\uc5d0\uc11c \uc5ff\ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\uc774\ub780 \ub0b4\ubd80\uc758 \"\ud558\uba54\ub124\uc774 \ud6c4\uc784\uc790 \uc120\ucd9c\" \uc6c0\uc9c1\uc784\uc740 \uc774\ub780\uc758 \uc815\uce58\uc801 \ubd88\ud655\uc2e4\uc131\uc744 \uac00\uc911\uc2dc\ud0a4\uace0 \uc788\uc73c\uba70, \uc774\ub294 \uc5ed\ub0b4 \uae34\uc7a5\uc744 \ub354\uc6b1 \uace0\uc870\uc2dc\ud0ac \uc218 \uc788\ub294 \ubcc0\uc218\ub85c \uc791\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc815\ubd80\uac00 \uc911\ub3d9 \uccb4\ub958 \uad6d\ubbfc\uc758 \uc721\ub85c \ub300\ud53c \uacc4\ud68d\uc744 \uc218\ub9bd\ud558\ub294 \uac83\uc740 \uc0ac\ud0dc\uc758 \uc2ec\uac01\uc131\uc744 \uac04\uc811\uc801\uc73c\ub85c \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.</p> <p>\ud22c\uc790 \uc804\ub7b5: *   \ub9ac\uc2a4\ud06c \ud5e4\uc9c0: \ud3ec\ud2b8\ud3f4\ub9ac\uc624\uc758 \ubc29\uc5b4\uc801 \uc131\uaca9\uc744 \uac15\ud654\ud558\uace0, \uc6d0\uc720 \ubc0f \ucc9c\uc5f0\uac00\uc2a4 \uc120\ubb3c \ub4f1 \uc5d0\ub108\uc9c0 \uad00\ub828 \ud30c\uc0dd\uc0c1\ud488\uc744 \ud1b5\ud55c \ud5e4\uc9c0 \uc804\ub7b5\uc744 \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4. *   \ubc29\uc0b0\uc8fc \ubc0f \uc6d0\uc790\uc7ac: \uc9c0\uc815\ud559\uc801 \uae34\uc7a5 \uc2ec\ud654\uc5d0 \ub530\ub77c \ub2e8\uae30\uc801\uc73c\ub85c \ubc29\uc0b0 \uad00\ub828 \uae30\uc5c5\uacfc \uae08, \uc740 \ub4f1 \uc548\uc804\uc790\uc0b0 \uc131\uaca9\uc758 \uc6d0\uc790\uc7ac\uc5d0 \ub300\ud55c \uad00\uc2ec\uc774 \ub192\uc544\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. *   \uc5d0\ub108\uc9c0 \uc139\ud130 \uc120\ubcc4\uc801 \uc811\uadfc: \uc5d0\ub108\uc9c0 \uae30\uc5c5 \uc911\uc5d0\uc11c\ub3c4 \uc9c0\uc815\ud559\uc801 \uc704\ud5d8\uc5d0 \uc0c1\ub300\uc801\uc73c\ub85c \ub35c \ub178\ucd9c\ub418\uac70\ub098, \uc5d0\ub108\uc9c0 \uc804\ud658 \ubc0f \uc2e0\uc7ac\uc0dd\uc5d0\ub108\uc9c0 \uad00\ub828 \uae30\uc220\uc744 \ubcf4\uc720\ud55c \uae30\uc5c5\ub4e4\uc744 \uc120\ubcc4\uc801\uc73c\ub85c \uc811\uadfc\ud558\ub294 \uc804\ub7b5\uc774 \uc720\ud6a8\ud569\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \ub2e8\uae30\uc801\uc778 \uc5d0\ub108\uc9c0 \uc139\ud130\ub294 \ub192\uc740 \ubcc0\ub3d9\uc131\uc5d0 \ub178\ucd9c\ub420 \uc218 \uc788\uc74c\uc744 \uc778\uc9c0\ud574\uc57c \ud569\ub2c8\ub2e4. *   \ud658\uc728 \ubcc0\ub3d9\uc131 \uad00\ub9ac: \uad6d\uc81c \uc815\uc138 \ubd88\uc548\uc815\uc740 \ub2ec\ub7ec \uac15\uc138\ub85c \uc774\uc5b4\uc9c8 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\ubbc0\ub85c, \ud658\uc728 \ubcc0\ub3d9\uc131\uc5d0 \ub300\ube44\ud55c \ud3ec\uc9c0\uc158 \uc870\uc815\uc774 \ud544\uc694\ud569\ub2c8\ub2e4.</p> <p>\ub098. \uae30\uc220 \uc139\ud130\uc758 \uc9c0\uc18d\uc801\uc778 \ud601\uc2e0\uacfc AI \uc778\ud504\ub77c \ud22c\uc790</p> <p>\uc911\ub3d9\ubc1c \ub9ac\uc2a4\ud06c\uac00 \uc2dc\uc7a5 \uc804\ubc18\uc758 \ubd88\ud655\uc2e4\uc131\uc744 \ub192\uc774\ub294 \uac00\uc6b4\ub370, \uae30\uc220 \uc139\ud130\uc5d0\uc11c\ub294 \uc5d4\ube44\ub514\uc544\uac00 \uad11\uc790\uacf5\ud559\uc5c5\uccb4\uc5d0 5.8\uc870 \uc6d0\uc744 \ud22c\uc790\ud588\ub2e4\ub294 \uc18c\uc2dd\uc774 \uc804\ud574\uc84c\uc2b5\ub2c8\ub2e4. \uc774\ub294 AI \uc2dc\ub300\uc758 \ud575\uc2ec\uc778 \uace0\uc18d \ub370\uc774\ud130 \ucc98\ub9ac \ubc0f \ud1b5\uc2e0 \uae30\uc220\uc758 \uc911\uc694\uc131\uc744 \ubc29\uc99d\ud558\uba70, AI \uc778\ud504\ub77c \ud655\ucda9\uc774 \uc9c0\uc18d\uc801\uc73c\ub85c \uac00\uc18d\ud654\ub420 \uac83\uc784\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \uc5d4\ube44\ub514\uc544\uc758 \uc774\ub7ec\ud55c \uc804\ub7b5\uc801 \ud22c\uc790\ub294 AI \uae30\uc220 \ubc1c\uc804\uc744 \uc704\ud55c \ud558\ub4dc\uc6e8\uc5b4 \ubc0f \ud1b5\uc2e0 \uc778\ud504\ub77c \uad6c\ucd95 \uacbd\uc7c1\uc774 \uc2ec\ud654\ub418\uace0 \uc788\uc74c\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.</p> <p>\ud22c\uc790 \uc804\ub7b5: *   AI \uc778\ud504\ub77c \ud575\uc2ec \uae30\uc5c5: \uc778\uacf5\uc9c0\ub2a5 \uc5f0\uc0b0\uc5d0 \ud544\uc218\uc801\uc778 \ubc18\ub3c4\uccb4(GPU), \uace0\ub300\uc5ed\ud3ed \uba54\ubaa8\ub9ac(HBM) \ubfd0\ub9cc \uc544\ub2c8\ub77c, \uc5d4\ube44\ub514\uc544\uc758 \ud22c\uc790\uc640 \uac19\uc774 AI \ub370\uc774\ud130\uc13c\ud130 \ub0b4 \uad11\ud559 \ud1b5\uc2e0 \ubc0f \ub0c9\uac01 \uae30\uc220 \ub4f1 \uad00\ub828 \uc778\ud504\ub77c\ub97c \uc81c\uacf5\ud558\ub294 \uae30\uc5c5\ub4e4\uc5d0 \ub300\ud55c \uc911\uc7a5\uae30\uc801 \uad00\uc810\uc758 \ud22c\uc790\ub97c \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4. *   \uc120\ubcc4\uc801 \uc131\uc7a5\uc8fc \ud22c\uc790: \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \ubd88\uc548\uc815 \uc18d\uc5d0\uc11c\ub3c4 AI, \uc790\uc728\uc8fc\ud589, \ub85c\ubd07 \ub4f1 \ubbf8\ub798 \uc131\uc7a5 \ub3d9\ub825\uc744 \ud655\ubcf4\ud55c \uae30\uc220 \uae30\uc5c5\ub4e4\uc740 \uafb8\uc900\ud55c \uad00\uc2ec\uc744 \ubc1b\uc744 \uac83\uc785\ub2c8\ub2e4. \ub2e4\ub9cc, \uace0\uae08\ub9ac \ud658\uacbd\uacfc \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub97c \uace0\ub824\ud558\uc5ec \uae30\uc5c5\uc758 \ud380\ub354\uba58\ud138\uacfc \ud604\uae08\ud750\ub984\uc744 \uba74\ubc00\ud788 \ubd84\uc11d\ud55c \ud6c4 \uc120\ubcc4\uc801 \ud22c\uc790\uac00 \uc694\uad6c\ub429\ub2c8\ub2e4. *   \ubc38\ub958\uc5d0\uc774\uc158 \uc810\uac80: AI \uad00\ub828 \uc8fc\uc2dd\ub4e4\uc758 \ub192\uc740 \ubc38\ub958\uc5d0\uc774\uc158 \ubd80\ub2f4\uc774 \uc5ec\uc804\ud558\ubbc0\ub85c, \uc131\uc7a5 \uc7a0\uc7ac\ub825\uacfc \ud604\uc7ac \uac00\uce58 \uac04\uc758 \uade0\ud615\uc744 \uc2e0\uc911\ud558\uac8c \ud3c9\uac00\ud558\ub294 \uac83\uc774 \uc911\uc694\ud569\ub2c8\ub2e4.</p> <p>\ub2e4. \uad6d\ub0b4 \uc99d\uc2dc\uc758 \ud68c\ubcf5 \ud0c4\ub825\uc131\uacfc \uac1c\uc778 \ud22c\uc790\uc790 \ub3d9\ud5a5</p> <p>\uad6d\ub0b4 \ucf54\uc2a4\ud53c \uc2dc\uc7a5\uc740 \uacfc\uac70 \uc911\ub3d9 \ub9ac\uc2a4\ud06c \ubc1c\uc0dd \uc2dc \ud55c \ub2ec \uc774\ub0b4\uc5d0 \ub300\ubd80\ubd84 \ud68c\ubcf5\ud588\ub358 \uc5ed\uc0ac\uc801 \ub370\uc774\ud130\ub97c \uac00\uc9c0\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub610\ud55c, \"\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4\"\ub294 \ubd84\uc11d \uc18d\uc5d0\uc11c \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc774 \ucf54\uc2a4\ud53c\ub97c \"\uba71\uc0b4 \uc7a1\uace0 \uac04\ub2e4\"\ub294 \uae30\uc0ac\ub294 \uad6d\ub0b4 \uc99d\uc2dc\uc758 \uc800\ub825\uc744 \ubcf4\uc5ec\uc8fc\ub294 \ub3d9\uc2dc\uc5d0 \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc758 \uc601\ud5a5\ub825\uc774 \ud655\ub300\ub418\uc5c8\uc74c\uc744 \ub098\ud0c0\ub0c5\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \uacfc\uac70\uc758 \ud68c\ubcf5\uc138\uac00 \ud604\uc7ac\uc758 \uc0c1\ud669\uc744 100% \ub300\ubcc0\ud558\uc9c0\ub294 \uc54a\uc2b5\ub2c8\ub2e4. \ud604\uc7ac\uc758 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub294 \uacfc\uac70\uc640\ub294 \ub2e4\ub978 \ubcf5\ud569\uc801\uc778 \uc694\uc18c(\uae00\ub85c\ubc8c \uace0\uae08\ub9ac \uc7a5\uae30\ud654, \uacf5\uae09\ub9dd \uc7ac\ud3b8 \ub4f1)\uc640 \uc5bd\ud600 \uc788\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\ud22c\uc790 \uc804\ub7b5: *   \uc120\ubcc4\uc801 \ud3ec\ud2b8\ud3f4\ub9ac\uc624 \uad6c\ucd95: \ucf54\uc2a4\ud53c \ub0b4\uc5d0\uc11c\ub3c4 \uc911\ub3d9 \ub9ac\uc2a4\ud06c\uc640 \uc5d0\ub108\uc9c0 \uac00\uaca9 \ubcc0\ub3d9\uc5d0 \uc0c1\ub300\uc801\uc73c\ub85c \ub35c \ubbfc\uac10\ud55c \ub0b4\uc218 \uc911\uc2ec \uae30\uc5c5, \ud639\uc740 \uac15\ub825\ud55c \uae30\uc220 \uacbd\uc7c1\ub825\uc744 \ubc14\ud0d5\uc73c\ub85c \ud55c \uc218\ucd9c \uae30\uc5c5\uc5d0 \uc8fc\ubaa9\ud574\uc57c \ud569\ub2c8\ub2e4. *   \ubc29\uc5b4\uc801 \uc139\ud130 \uac80\ud1a0: \uc720\ud2f8\ub9ac\ud2f0, \ud1b5\uc2e0 \ub4f1 \uacbd\uae30 \ubc29\uc5b4\uc801 \uc131\uaca9\uc758 \uc139\ud130\uc5d0 \ub300\ud55c \uad00\uc2ec\ub3c4 \uc720\ud6a8\ud569\ub2c8\ub2e4. *   \uc218\ucd9c \uacbd\uc7c1\ub825 \uac15\ud654 \uae30\uc5c5: \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc774 \uc6d0\uac00 \ubd80\ub2f4\uc73c\ub85c \uc791\uc6a9\ud560 \uc218 \uc788\uc73c\ub098, \uadf8\ub7fc\uc5d0\ub3c4 \ubd88\uad6c\ud558\uace0 \ub3c5\ubcf4\uc801\uc778 \uae30\uc220\ub825\uacfc \uac00\uaca9 \uacbd\uc7c1\ub825\uc744 \ubc14\ud0d5\uc73c\ub85c \uae00\ub85c\ubc8c \uc2dc\uc7a5\uc5d0\uc11c \ud655\uace0\ud55c \uc704\uce58\ub97c \uc810\ud558\uace0 \uc788\ub294 \uc218\ucd9c \uae30\uc5c5\ub4e4\uc740 \uae30\ud68c\ub97c \ubaa8\uc0c9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. *   \uac1c\uc778 \ud22c\uc790\uc790 \ub3d9\ud5a5 \uc8fc\uc2dc: \uad6d\ub0b4 \uc99d\uc2dc\uc5d0\uc11c \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc758 \uc218\uae09 \uc601\ud5a5\ub825\uc774 \ucee4\uc9c4 \ub9cc\ud07c, \uc774\ub4e4\uc758 \ud22c\uc790 \uc2ec\ub9ac\uc640 \ud3ec\uc9c0\uc158 \ubcc0\ud654\ub97c \uba74\ubc00\ud788 \uad00\ucc30\ud558\ub294 \uac83\uc774 \uc911\uc694\ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/#3","title":"3. \u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ul> <li>\uc911\ub3d9 \uc815\uc138 \ubcc0\ud654: \uc774\ub780\uc758 \ud558\uba54\ub124\uc774 \ud6c4\uc784\uc790 \uc120\ucd9c \uc9c4\ud589 \uc0c1\ud669 \ubc0f \uc774\ub780\uacfc \uc8fc\ubcc0\uad6d, \uad6d\uc81c \uc0ac\ud68c \uac04\uc758 \uc678\uad50\uc801/\uad70\uc0ac\uc801 \ucda9\ub3cc \uc591\uc0c1. \ud2b9\ud788 \ud638\ub974\ubb34\uc988 \ud574\ud611 \ub4f1 \uc8fc\uc694 \ud574\uc0c1 \uc6b4\uc1a1\ub85c\uc758 \uc548\uc815\uc131 \uc5ec\ubd80.</li> <li>\uad6d\uc81c \uc720\uac00 \ubc0f LNG \uac00\uaca9 \ub3d9\ud5a5: WTI, \ube0c\ub80c\ud2b8\uc720 \ub4f1 \uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9 \ucd94\uc774 \ubc0f \uce74\ud0c0\ub974 LNG \uc2dc\uc124\uc758 \uc7ac\uac00\ub3d9 \uc5ec\ubd80, \uc720\ub7fd \ubc0f \uc544\uc2dc\uc544 \ucc9c\uc5f0\uac00\uc2a4 \uac00\uaca9.</li> <li>\uc8fc\uc694\uad6d \uc911\uc559\uc740\ud589 \ud1b5\ud654\uc815\ucc45 \uc2a4\ud0e0\uc2a4: \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc73c\ub85c \uc778\ud55c \uc778\ud50c\ub808\uc774\uc158 \uc7ac\uc810\ud654 \uac00\ub2a5\uc131\uc5d0 \ub300\ube44\ud558\uc5ec \ubbf8\uad6d \uc5f0\ubc29\uc900\ube44\uc81c\ub3c4(Fed), \uc720\ub7fd\uc911\uc559\uc740\ud589(ECB), \ud55c\uad6d\uc740\ud589 \ub4f1 \uc8fc\uc694\uad6d \uc911\uc559\uc740\ud589\uc758 \uae08\ub9ac \uc778\uc0c1 \ub610\ub294 \ub3d9\uacb0\uc5d0 \ub300\ud55c \ubc1c\uc5b8 \ubc0f \uacb0\uc815.</li> <li>\uae00\ub85c\ubc8c \uc778\ud50c\ub808\uc774\uc158 \uc9c0\ud45c: \ubbf8\uad6d \uc18c\ube44\uc790\ubb3c\uac00\uc9c0\uc218(CPI), \uc0dd\uc0b0\uc790\ubb3c\uac00\uc9c0\uc218(PPI) \ub4f1 \uc778\ud50c\ub808\uc774\uc158 \uad00\ub828 \uc9c0\ud45c\uc758 \ubc1c\ud45c.</li> <li>\uc8fc\uc694 \uae30\uc220 \uae30\uc5c5 \uc2e4\uc801 \ubc1c\ud45c \ubc0f \uac00\uc774\ub358\uc2a4: \uc5d4\ube44\ub514\uc544\ub97c \ube44\ub86f\ud55c \ubc18\ub3c4\uccb4 \ubc0f AI \uad00\ub828 \uae30\uc5c5\ub4e4\uc758 \uc2e4\uc801 \ubc1c\ud45c\uc640 \ud5a5\ud6c4 \uc0ac\uc5c5 \uc804\ub9dd \uac00\uc774\ub358\uc2a4.</li> <li>\uad6d\ub0b4\uc678 \uc81c\uc870\uc5c5 PMI \uc9c0\ud45c: \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc774 \uae00\ub85c\ubc8c \uc81c\uc870\uc5c5 \ud65c\ub3d9\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5 \ubc0f \uacbd\uae30 \uce68\uccb4 \uac00\ub2a5\uc131\uc744 \uac00\ub2a0\ud560 \uc218 \uc788\ub294 \uc911\uc694\ud55c \uc9c0\ud45c.</li> </ul> <p>\uc885\ud569\uc801\uc73c\ub85c \ubcfc \ub54c, 2026\ub144 3\uc6d4 \ucd08 \uae00\ub85c\ubc8c \uc2dc\uc7a5\uc740 \uc911\ub3d9 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc640 \uc5d0\ub108\uc9c0 \uc2dc\uc7a5 \ubd88\uc548\uc815\uc774\ub77c\ub294 \ub2e8\uae30\uc801\uc774\uace0 \uac15\ub825\ud55c \ud558\ubc29 \uc555\ub825 \uc18d\uc5d0\uc11c\ub3c4 AI \uc778\ud504\ub77c \ud655\ucda9\uc774\ub77c\ub294 \uc911\uc7a5\uae30\uc801 \uc131\uc7a5 \ub3d9\ub825\uc744 \ub3d9\uc2dc\uc5d0 \uac00\uc838\uac00\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud22c\uc790\uc790 \uc5ec\ub7ec\ubd84\uaed8\uc11c\ub294 \ub2e8\uae30\uc801\uc778 \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc5d0 \uc77c\ud76c\uc77c\ube44\ud558\uae30\ubcf4\ub2e4\ub294, \uc704\ud5d8 \uad00\ub9ac\uc5d0 \uc9d1\uc911\ud558\uba74\uc11c\ub3c4 \ubbf8\ub798 \uc131\uc7a5\uc744 \uacac\uc778\ud560 \uc139\ud130\uc5d0 \ub300\ud55c \uc120\ubcc4\uc801\uc774\uace0 \uc804\ub7b5\uc801\uc778 \uc811\uadfc\uc744 \ud1b5\ud574 \uae30\ud68c\ub97c \ubaa8\uc0c9\ud558\uc2dc\uae30\ub97c \uad8c\uace0 \ub4dc\ub9bd\ub2c8\ub2e4.</p> <p>\ubcf8 \ubcf4\uace0\uc11c\ub294 \ub274\uc2a4 \ub370\uc774\ud130\ub97c \uae30\ubc18\uc73c\ub85c \uc791\uc131\ub418\uc5c8\uc73c\uba70, \ud22c\uc790 \uacb0\uc815\uc740 \ud56d\uc0c1 \ucda9\ubd84\ud55c \ucd94\uac00 \ubd84\uc11d\uacfc \uc804\ubb38\uac00\uc758 \uc870\uc5b8\uc744 \ud1b5\ud574 \uc774\ub8e8\uc5b4\uc838\uc57c \ud569\ub2c8\ub2e4.</p> <p>\uac10\uc0ac\ud569\ub2c8\ub2e4.</p> <p>[\uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8]</p>"}]}