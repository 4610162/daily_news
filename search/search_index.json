{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/","title":"Daily AI \uacbd\uc81c \ub9ac\ud3ec\ud2b8","text":"<p>\ub9e4\uc77c \uc5c5\ub370\uc774\ud2b8\ub418\ub294 AI \uacbd\uc81c \ub274\uc2a4 \ub9ac\ud3ec\ud2b8\uc785\ub2c8\ub2e4. \uc67c\ucabd \uba54\ub274(\ub610\ub294 \uc0c1\ub2e8 \ud0ed)\uc758 Daily Reports\uc5d0\uc11c \ucd5c\uc2e0 \ub9ac\ud3ec\ud2b8\ub97c \ud655\uc778\ud558\uc138\uc694!</p>"},{"location":"reports/2026-02-28/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-02-28)","text":""},{"location":"reports/2026-02-28/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \"3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8 \uae30\ud68c\uc778\ub370\u2026\" 40\ub300 \uc9c1\uc7a5\uc778 \uba58\ubd95 \uc628 \uae4c\ub2ed [\ub3c8 \ubc84\ub294 \ubc95 \uc544\ub07c\ub294 \ubc95]</li> <li>[\uacbd\uc81c] \ud398\ub77c\ub9ac \ud0c0\ub358 \uc190\ud765\ubbfc, 1\uc5b5\uc9dc\ub9ac \u8eca \uc6b4\uc804 \ud3ec\ucc29\u2026\ubbf8\uad6d '\ub4e4\uc369'</li> <li>[\uacbd\uc81c] \u4f0a \ub9ac\ube59 \ube0c\ub79c\ub4dc '\uc2a4\ud14c\ud310\ud50c\ub77c\uc2a4\ud2b8', \uad6d\ub0b4 \ucf54\uc2a4\ud2b8\ucf54\uc5d0 \ud5ec\ud53c\uce74\ud2b8 \ucd9c\uc2dc</li> <li>[\uacbd\uc81c] \"\ub9e4\uc77c \ub2ec\ub838\ub354\ub2c8 \ud1b5\uc7a5\uc5d0 \ub3c8 \ub4e4\uc5b4\uc640\uc694\"\u2026\ub7ec\ub2dd\uc871\ub4e4 \ud658\ud638\ud55c \uc774\uc720</li> <li>[\uacbd\uc81c] \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 2\uc8fc \uc5f0\uc18d \uc0c1\uc2b9\u2026\uacbd\uc720\ub294 \ub2e4\uc74c \uc8fc\ub3c4 \uc624\ub97c \ub4ef</li> <li>[\uc99d\uad8c] \uae00\ub85c\ubc8c \ud070\uc190 4000\uc5b5 \uc4f8\uc5b4\ub2f4\ub354\ub2c8\u2026\ud55c \ub2ec \ub9cc\uc5d0 34% '\uae09\ub4f1' [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] [\uc18d\ubcf4] \ubbf8\uad6d \uc774\ub780 \uacf5\uaca9, \ube44\ud2b8\ucf54\uc778 4% \uc774\uc0c1 \uae09\ub77d, 6\ub9cc4000\ub2ec\ub7ec \ubd95\uad34</li> <li>[\uc99d\uad8c] \ucda9\uaca9 \uc18c\uc2dd\uc5d0 \uc798\ub098\uac00\ub358 \uc8fc\uac00 '\ud718\uccad'\u2026\ud55c\uad6d\uc804\ub825 \uac1c\ubbf8 \uc5b4\uca4c\ub098 [\uc885\ubaa9+]</li> <li>[\uc99d\uad8c] \uadf8\uc57c\ub9d0\ub85c '\ud55c \ub057 \ucc28\uc774'\u2026'\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15 \ub09c \uc774\uc720 \uc788\uc5c8\ub2e4 [\ubc15\uc8fc\uc5f0\uc758 \uc5ec\uc758\ub3c4 \ub098\uce68\ubc18]</li> <li>[\uc99d\uad8c] \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548, \uae08\uc735\uc8fc \uac15\ud0c0 \u2026UBS \"\ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd\" [\uae40\ud604\uc11d\uc758 \uc6d4\uc2a4\ud2b8\ub9ac\ud2b8\ub098\uc6b0]</li> </ol>"},{"location":"reports/2026-02-28/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-02-28/#2026-02-28_1","title":"2026\ub144 02\uc6d4 28\uc77c \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ubd84\uc11d \ubcf4\uace0\uc11c","text":"<p>\uc791\uc131\uc790: \uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8</p> <p>\uc694\uc57d: 2026\ub144 2\uc6d4 28\uc77c \ud604\uc7ac, \uc2dc\uc7a5\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654, \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uac00\ub2a5\uc131, \uadf8\ub9ac\uace0 \uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\uc5d0 \ud63c\ub780\uc744 \uacaa\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub9cc\uc73c\ub85c \ubd84\uc11d\ud558\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \uc2ec\ub9ac\ub294 \ubd88\uc548\uc815\ud558\uba70 \ud22c\uc790\uc5d0 \uc2e0\uc911\ud55c \uc811\uadfc\uc774 \ud544\uc694\ud55c \uc2dc\uc810\uc785\ub2c8\ub2e4.</p>"},{"location":"reports/2026-02-28/#1","title":"1. \ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc","text":"<ul> <li>\uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c: \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9 \uad00\ub828 \ub274\uc2a4\uc5d0 \ub530\ub978 \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uac00 \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ubbf8\uce58\ub294 \uc9c1\uc811\uc801\uc778 \uc601\ud5a5\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc774\ub294 \ud5a5\ud6c4 \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc744 \ud655\ub300\uc2dc\ud0ac \uc218 \uc788\ub294 \uc8fc\uc694 \uc694\uc778\uc785\ub2c8\ub2e4.</li> <li>\uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc5d0 \ub300\ud55c \uc6b0\ub824\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ud2b9\ud788, \uae08\uc735\uc8fc \ud0c0\uaca9\uc740 \uc2dc\uc7a5\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ub354\uc6b1 \uc99d\ud3ed\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9: \uc804\uad6d \uc8fc\uc720\uc18c \uae30\ub984\uac12 \uc0c1\uc2b9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\ub294 \uc694\uc778\uc73c\ub85c \uc791\uc6a9\ud558\uba70, \uc18c\ube44 \uc2ec\ub9ac \uc704\ucd95 \ubc0f \uae30\uc5c5 \ube44\uc6a9 \uc99d\uac00\ub85c \uc774\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#2","title":"2. \ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2.1. \uac70\uc2dc \uacbd\uc81c \ubd84\uc11d:</p> <p>\ud604\uc7ac \ub274\uc2a4 \ub370\uc774\ud130\ub294 \uc81c\ud55c\uc801\uc774\uc9c0\ub9cc, \uc804\ubc18\uc801\uc778 \uc2dc\uc7a5 \ubd84\uc704\uae30\ub294 \ubd88\uc548\uc815\ud568\uc744 \ub098\ud0c0\ub0c5\ub2c8\ub2e4. \ubbf8\uad6d-\uc774\ub780 \uacf5\uaca9\uc73c\ub85c \uc778\ud55c \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\ub294 \uad6d\uc81c \uc720\uac00 \uc0c1\uc2b9\uc744 \uc57c\uae30\ud558\uace0, \uc774\ub294 \uc804 \uc138\uacc4\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788, 2026\ub144 \ucd08\ubd80\ud130 \uc9c0\uc18d\ub41c \uc5d0\ub108\uc9c0 \uac00\uaca9 \uc0c1\uc2b9\uc740 \uae30\uc5c5\uc758 \uc0dd\uc0b0 \ube44\uc6a9 \uc99d\uac00\uc640 \uc18c\ube44\uc790\uc758 \uad6c\ub9e4\ub825 \uac10\uc18c\ub85c \uc774\uc5b4\uc838 \uacbd\uc81c \uc131\uc7a5\uc744 \ub454\ud654\uc2dc\ud0ac \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4.</p> <p>2.2. \uae08\uc735 \uc2dc\uc7a5 \ubd84\uc11d:</p> <ul> <li>\uc8fc\uc2dd \uc2dc\uc7a5: \ud55c\uad6d\uc804\ub825 \uc8fc\uac00 \ud558\ub77d\uc740 \uac1c\ubcc4 \uc885\ubaa9\uc758 \uc774\uc288\ub97c \ub118\uc5b4, \uc2dc\uc7a5 \uc804\ubc18\uc758 \ubd88\uc548 \uc2ec\ub9ac\ub97c \ubc18\uc601\ud569\ub2c8\ub2e4. \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uacfc UBS\uc758 \ubbf8\uad6d \uc8fc\uc2dd \uc911\ub9bd \uc758\uacac\uc740 \ud22c\uc790 \uc2ec\ub9ac\ub97c \uc704\ucd95\uc2dc\ud0a4\uace0, \uc8fc\uc2dd \uc2dc\uc7a5\uc758 \ud558\ubc29 \uc555\ub825\uc744 \ub192\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5: \ube44\ud2b8\ucf54\uc778 \uae09\ub77d\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc5d0 \ub300\ud55c \ubbfc\uac10\uc131\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\uac00 \uac15\ud654\ub418\uba74\uc11c \uc554\ud638\ud654\ud3d0 \uc2dc\uc7a5\uc5d0\uc11c \uc790\uae08 \uc774\ud0c8\uc774 \ubc1c\uc0dd\ud55c \uac83\uc73c\ub85c \ud574\uc11d\ub429\ub2c8\ub2e4.</li> <li>\ucc44\uad8c \uc2dc\uc7a5: \uae08\ub9ac \uc778\uc0c1 \uac00\ub2a5\uc131\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c \ucc44\uad8c \uac00\uaca9\uc740 \ud558\ub77d \uc555\ub825\uc744 \ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\ub294 \uc548\uc804 \uc790\uc0b0 \uc120\ud638 \uc2ec\ub9ac\ub97c \uc790\uadf9\ud558\uc5ec \ucc44\uad8c \uc218\uc694\ub97c \uc99d\uac00\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> <p>2.3. \ud22c\uc790 \uc804\ub7b5:</p> <ul> <li>\uc704\ud5d8 \uc790\uc0b0 \ube44\uc911 \ucd95\uc18c: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc640 \uae08\uc735 \uc2dc\uc2a4\ud15c \ubd88\uc548\uc774 \uc9c0\uc18d\ub418\ub294 \uc0c1\ud669\uc5d0\uc11c\ub294 \uc8fc\uc2dd, \uc554\ud638\ud654\ud3d0 \ub4f1 \uc704\ud5d8 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ucd95\uc18c\ud558\uace0, \uc548\uc804 \uc790\uc0b0\uc758 \ube44\uc911\uc744 \ud655\ub300\ud558\ub294 \uac83\uc774 \ubc14\ub78c\uc9c1\ud569\ub2c8\ub2e4.</li> <li>\ud604\uae08 \ud655\ubcf4: \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc774 \ud655\ub300\ub420 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\ubbc0\ub85c, \ud604\uae08 \ud655\ubcf4\ub97c \ud1b5\ud574 \ud22c\uc790 \uae30\ud68c\ub97c \ud3ec\ucc29\ud558\uac70\ub098 \uc190\uc2e4\uc744 \ucd5c\uc18c\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uac00\uce58 \ud22c\uc790: \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc131\uc7a5 \uac00\ub2a5\uc131\uc774 \ub192\uc740 \uac00\uce58\uc8fc\uc5d0 \ud22c\uc790\ud558\ub294 \uc804\ub7b5\uc744 \uace0\ub824\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\ubd84\uc0b0 \ud22c\uc790: \ud2b9\uc815 \uc790\uc0b0\uc5d0 \uc9d1\uc911 \ud22c\uc790\ud558\ub294 \uac83\uc744 \uc9c0\uc591\ud558\uace0, \ub2e4\uc591\ud55c \uc790\uc0b0\uc5d0 \ubd84\uc0b0 \ud22c\uc790\ud558\uc5ec \uc704\ud5d8\uc744 \ubd84\uc0b0\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9: '\ud1f4\uc9c1\uc5f0\uae08'\uc73c\ub85c \ub300\ubc15\uc744 \ub0b8 \uc0ac\ub840\ucc98\ub7fc, \uc7a5\uae30\uc801\uc778 \uad00\uc810\uc5d0\uc11c \uc548\uc815\uc801\uc778 \uc218\uc775\uc744 \ucd94\uad6c\ud558\ub294 \ud1f4\uc9c1\uc5f0\uae08 \ud65c\uc6a9 \uc804\ub7b5\uc744 \uc801\uadf9\uc801\uc73c\ub85c \uace0\ub824\ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"reports/2026-02-28/#3","title":"3. \u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<ul> <li>\ubbf8\uad6d \uc5f0\ubc29\uc900\ube44\uc81c\ub3c4(Fed)\uc758 \uae08\ub9ac \uacb0\uc815: \uae08\ub9ac \uc778\uc0c1 \uc9c0\uc18d \uc5ec\ubd80\ub294 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c, Fed\uc758 \uae08\ub9ac \uacb0\uc815 \ubc0f \uad00\ub828 \ubc1c\uc5b8\uc5d0 \uc8fc\uc758\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\uc5d0 \ub530\ub978 \uad6d\uc81c \uc720\uac00 \ubcc0\ub3d9\uc740 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uc744 \ub192\uc774\uace0, \uacbd\uc81c \uc131\uc7a5\uc5d0 \ubd80\uc815\uc801\uc778 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc73c\ubbc0\ub85c \uc9c0\uc18d\uc801\uc73c\ub85c \ubaa8\ub2c8\ud130\ub9c1\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\ubbf8\uad6d-\uc774\ub780 \uad00\uacc4 \uc804\uac1c: \ubbf8\uad6d-\uc774\ub780 \uad00\uacc4\uc758 \ud5a5\ud6c4 \uc804\uac1c \uc591\uc0c1\uc740 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uc758 \uc2ec\uac01\uc131\uc744 \uacb0\uc815\ud558\uace0, \uae08\uc735 \uc2dc\uc7a5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uad6d\ub0b4 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5 \ub3d9\ud5a5: 3\uc5b5\ub300 \uc11c\uc6b8 \uc544\ud30c\ud2b8\uc5d0 \ub300\ud55c \uad00\uc2ec\uc740 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ubbf8\ubb18\ud55c \ubcc0\ud654\ub97c \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc758 \ud5a5\ud6c4 \ub3d9\ud5a5\uc744 \uc8fc\uc2dc\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc0ac\ubaa8\ub300\ucd9c \uad00\ub828 \uae08\uc735\uae30\uad00 \uac74\uc804\uc131: \uc0ac\ubaa8\ub300\ucd9c \ubd88\uc548\uc774 \uae08\uc735 \uc2dc\uc2a4\ud15c \uc804\ubc18\uc73c\ub85c \ud655\uc0b0\ub420 \uac00\ub2a5\uc131\uc5d0 \ub300\ube44\ud558\uc5ec \uad00\ub828 \uae08\uc735\uae30\uad00\uc758 \uac74\uc804\uc131\uc744 \uba74\ubc00\ud788 \uc0b4\ud3b4\uc57c \ud569\ub2c8\ub2e4.</li> </ul> <p>Disclaimer: \ubcf8 \ubcf4\uace0\uc11c\ub294 \uc81c\ud55c\uc801\uc778 \ub274\uc2a4 \ub370\uc774\ud130\ub97c \uae30\ubc18\uc73c\ub85c \uc791\uc131\ub418\uc5c8\uc73c\uba70, \ud22c\uc790 \uc790\ubb38\uc774 \uc544\ub2d9\ub2c8\ub2e4. \ud22c\uc790 \uacb0\uc815\uc740 \ubcf8\uc778\uc758 \ud310\ub2e8\uacfc \ucc45\uc784 \ud558\uc5d0 \uc2e0\uc911\ud558\uac8c \uc774\ub8e8\uc5b4\uc838\uc57c \ud569\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/","title":"\ud83d\udcd1 \ub370\uc77c\ub9ac \uacbd\uc81c \ube0c\ub9ac\ud551 \ubcf4\uace0\uc11c (2026-03-02)","text":""},{"location":"reports/2026-03-02/#top-10","title":"\ud83d\udcf0 \uc8fc\uc694 \ub274\uc2a4 \ud5e4\ub4dc\ub77c\uc778 (TOP 10)","text":"<ol> <li>[\uacbd\uc81c] \"\uc544\ub9c8\uc874\uc758 UAE \ub370\uc774\ud130\uc13c\ud130,\uacf5\uaca9\ubc1b\uc544 \uc11c\ube44\uc2a4\uc911\ub2e8\"</li> <li>[\uacbd\uc81c] \uc774\ub780\uacf5\uc2b5 3\uc77c\ucc28 \u7f8e\uc99d\uc2dc \ub099\ud3ed \uc904\uc5ec\u2026\ubc29\uc0b0\uc8fc \uc77c\uc81c\ud788 \uc0c1\uc2b9</li> <li>[\uacbd\uc81c] \uc5d4\ube44\ub514\uc544,\uad11\uc790\uacf5\ud559\uc5c5\uccb4 \ub8e8\uba58\ud140,\ucf54\ud788\ub7f0\ud2b8\uc5d0 5.8\uc870\uc6d0 \ud22c\uc790</li> <li>[\uacbd\uc81c] \uce74\ud0c0\ub974, \uc774\ub780 \ub4dc\ub860 \uacf5\uaca9\uc5d0 \uc138\uacc4\ucd5c\ub300 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8</li> <li>[\uacbd\uc81c] \uc720\uac00 \uc804\ub9dd \"100\ub2ec\ub7ec \uc774\uc0c1\" vs \"\ub2f9\ubd84\uac04 80\ub2ec\ub7ec\ub300 \uac70\ub798\"</li> <li>[\uc99d\uad8c] \"\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4\"\u2026\uac1c\ubbf8\uad70\ub2e8, \ucf54\uc2a4\ud53c \uba71\uc0b4 \uc7a1\uace0 \uac04\ub2e4 [\ubd84\uc11d+]</li> <li>[\uc99d\uad8c] \uc911\ub3d9 \uccb4\ub958\uc790 1.7\ub9cc\uba85\u2026\uc815\ubd80, \uc721\ub85c \ub300\ud53c\uacc4\ud68d \uc218\ub9bd</li> <li>[\uc99d\uad8c] \uae40\ubcd1\uc8fc \uc790\ud0dd \ub2f4\ubcf4\ub85c\u2026MBK, \ud648\ud50c\ub7ec\uc2a4 \uc218\ud608\uc790\uae08 1000\uc5b5 \ub9c8\ub828</li> <li>[\uc99d\uad8c] '\uc624\uc77c \uc1fc\ud06c' \ub2e5\uce58\ub098\u2026\ub2db\ucf00\uc774, \uac1c\uc7a5 \ud558\uc790\ub9c8\uc790 2.7% \ud558\ub77d</li> <li>[\uc99d\uad8c] 2000\ub144 \uc774\ud6c4 \uc5ec\uc12f \ubc88 '\uc911\ub3d9 \ub9ac\uc2a4\ud06c'\u2026\ucf54\uc2a4\ud53c \ud55c\ub2ec \ub4a4 \ubaa8\ub450 \ud68c\ubcf5\ud588\ub2e4</li> </ol>"},{"location":"reports/2026-03-02/#_1","title":"\ud83d\udcca \uc2dc\uc7a5 \uc8fc\uc694 \uc9c0\ud45c (\uc804\uc77c \ub300\ube44)","text":"\uc9c0\ud45c\uba85 (\uae30\uc900\uc77c) \ud604\uc7ac\uac12 \uc804\uc77c\ub300\ube44 \uc784\uacc4\uac12 \uc0c1\ud0dc \uc7a5\ub2e8\uae30 \uae08\ub9ac\ucc28 (02/27) 0.59 -0.01 0.0 \u2705 \ub2ec\ub7ec \uc778\ub371\uc2a4 (02/20) 117.992 -0.244 120.0 \u2705 High Yield \uc2a4\ud504\ub808\ub4dc (02/26) 2.98 +0.04 4.0 \u2705 \uacf5\ud3ec \uc9c0\uc218 (VIX) (03/02) 21.82 +1.96 20.0 \u26a0\ufe0f"},{"location":"reports/2026-03-02/#ai","title":"\ud83e\udd16 AI \ubd84\uc11d \ubc0f \uc2dc\uc7a5 \uc804\ub9dd","text":""},{"location":"reports/2026-03-02/#_2","title":"\uacbd\uc81c \ubc0f \uae08\uc735 \uc804\ubb38 \uc560\ub110\ub9ac\uc2a4\ud2b8 \ubcf4\uace0\uc11c","text":"<p>\uae30\uc900 \uc2dc\uc810: 2026\ub144 03\uc6d4 02\uc77c</p>"},{"location":"reports/2026-03-02/#3","title":"\ud83c\udfaf \uc624\ub298\uc758 \uacbd\uc81c \ubc0f \uc2dc\uc7a5 \ud575\uc2ec \ud0a4\uc6cc\ub4dc (3\uac1c)","text":"<ol> <li>\uc911\ub3d9 \uc9c0\uc815\ud559\uc801 \ubd88\uc548\uc815\uc131 \uc2ec\ud654: \uc774\ub780 \uacf5\uc2b5, UAE \ub370\uc774\ud130\uc13c\ud130 \uacf5\uaca9, \uce74\ud0c0\ub974 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8 \ub4f1 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uad70\uc0ac\uc801 \ucda9\ub3cc \ubc0f \uc778\ud504\ub77c \uacf5\uaca9 \uc18c\uc2dd\uc774 \uc5f0\uc774\uc5b4 \ubc1c\uc0dd\ud558\uba70 \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uac00 \uc804\ub840 \uc5c6\uc774 \uace0\uc870\ub418\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uae00\ub85c\ubc8c \uacbd\uc81c \uc804\ubc18\uc5d0 \uc989\uac01\uc801\uc774\uace0 \uc2ec\ub300\ud55c \uc601\ud5a5\uc744 \ubbf8\uce58\uace0 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uae00\ub85c\ubc8c \uc5d0\ub108\uc9c0 \uacf5\uae09\ub9dd \uad50\ub780 \ubc0f \uc720\uac00 \ubcc0\ub3d9\uc131 \ud655\ub300: \uce74\ud0c0\ub974\uc758 \uc138\uacc4 \ucd5c\ub300 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8\uacfc \uc720\uac00 100\ub2ec\ub7ec \ub3cc\ud30c \uac00\ub2a5\uc131 \ub17c\uc758\ub294 \uc5d0\ub108\uc9c0 \uacf5\uae09\ub9dd\uc758 \ucde8\uc57d\uc131\uc744 \ub4dc\ub7ec\ub0b4\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uc5d0\ub108\uc9c0 \uac00\uaca9 \uae09\ub4f1\uc744 \ud1b5\ud55c \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825 \uac00\uc911 \ubc0f \uae00\ub85c\ubc8c \uacbd\uae30 \ub454\ud654 \uc6b0\ub824\ub97c \uc2ec\ud654\uc2dc\ud0a4\uace0 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc2dc\uc7a5 \ud0c4\ub825\uc131 \ubc0f \uc120\ud0dd\uc801 \uae30\uc220 \ud22c\uc790 \uae30\uc870: \ubbf8 \uc99d\uc2dc\uc758 \ub099\ud3ed \ucd95\uc18c, \ucf54\uc2a4\ud53c\uc758 \uc5ed\uc0ac\uc801 \ud68c\ubcf5 \ud0c4\ub825\uc131 \uc7ac\ud655\uc778, \uadf8\ub9ac\uace0 \uc5d4\ube44\ub514\uc544\uc758 \uad11\uc790\uacf5\ud559 \ud22c\uc790 \ub4f1\uc740 \ubd88\uc548\uc815\ud55c \uac70\uc2dc \ud658\uacbd \uc18d\uc5d0\uc11c\ub3c4 \uc2dc\uc7a5\uc758 \ub0b4\uc7ac\ub41c \ud68c\ubcf5\ub825\uacfc \ud2b9\uc815 \uace0\uc131\uc7a5 \uae30\uc220 \ubd84\uc57c\uc5d0 \ub300\ud55c \uc7a5\uae30\uc801 \ud22c\uc790 \uae30\uc870\uac00 \uacf5\uc874\ud558\uace0 \uc788\uc74c\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4.</li> </ol>"},{"location":"reports/2026-03-02/#_3","title":"\ud83d\udcc8 \uc885\ud569 \ubd84\uc11d \ubc0f \ud22c\uc790 \uc804\ub7b5","text":"<p>2026\ub144 3\uc6d4 2\uc77c \ud604\uc7ac, \uae00\ub85c\ubc8c \uacbd\uc81c\ub294 \uc911\ub3d9 \uc9c0\uc5ed\uc758 \uc804\uba74\uc801\uc778 \uc9c0\uc815\ud559\uc801 \uc704\uae30 \uace0\uc870\ub77c\ub294 \ucd08\uc720\uc758 \ub3c4\uc804\uc5d0 \uc9c1\uba74\ud574 \uc788\uc2b5\ub2c8\ub2e4. \uc544\ub9c8\uc874 UAE \ub370\uc774\ud130\uc13c\ud130 \uacf5\uaca9, \uc774\ub780\uc758 \uacf5\uc2b5 \uc9c0\uc18d, \uce74\ud0c0\ub974 LNG \uc2dc\uc124 \uc0dd\uc0b0 \uc911\ub2e8 \ub4f1\uc740 \ub2e8\uc21c\ud55c \uad6d\uc9c0\uc801 \ubd84\uc7c1\uc744 \ub118\uc5b4 \uae00\ub85c\ubc8c \ud575\uc2ec \uc778\ud504\ub77c\uc640 \uc5d0\ub108\uc9c0 \uacf5\uae09\ub9dd\uc744 \uc9c1\uc811\uc801\uc73c\ub85c \uc704\ud611\ud558\uba70 \uc2dc\uc2a4\ud15c \ub9ac\uc2a4\ud06c\ub85c \ud655\uc0b0\ub420 \uac00\ub2a5\uc131\uc744 \ub0b4\ud3ec\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788, \uc5d0\ub108\uc9c0 \uc2dc\uc7a5\uc758 \ubd88\ud655\uc2e4\uc131\uc740 \uc720\uac00 \uc804\ub9dd\uc774 '100\ub2ec\ub7ec \uc774\uc0c1'\uacfc '80\ub2ec\ub7ec\ub300'\ub85c \uadf9\uba85\ud558\uac8c \uc5c7\uac08\ub9ac\ub294 \uc0c1\ud669\uc5d0\uc11c \"\uc624\uc77c \uc1fc\ud06c\"\uc5d0 \ub300\ud55c \ud604\uc2e4\uc801\uc778 \uc6b0\ub824\ub97c \ud0a4\uc6b0\uace0 \uc788\uc73c\uba70, \ub2db\ucf00\uc774\uc758 \uac1c\uc7a5 \uc9c1\ud6c4 \uae09\ub77d\uc740 \uc774\ub7ec\ud55c \ubd88\uc548\uac10\uc774 \uc544\uc2dc\uc544 \uc2dc\uc7a5\uc5d0 \ubbf8\uce58\ub294 \uc989\uac01\uc801\uc778 \uc601\ud5a5\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.</p> <p>\uc885\ud569 \ubd84\uc11d:</p> <p>\ud604\uc7ac \uc2dc\uc7a5\uc740 \uc911\ub3d9 \uc0ac\ud0dc\uc758 \uc804\uac1c \uc591\uc0c1\uc5d0 \ub530\ub77c \uadf9\uc2ec\ud55c \ubcc0\ub3d9\uc131\uc744 \ubcf4\uc774\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ubc29\uc0b0\uc8fc\uac00 \uc77c\uc81c\ud788 \uc0c1\uc2b9\ud558\uace0 \ubbf8 \uc99d\uc2dc\uc758 \ub099\ud3ed\uc774 \uc904\uc5b4\ub4dc\ub294 \ud604\uc0c1, \uadf8\ub9ac\uace0 \uacfc\uac70 \uc911\ub3d9 \ub9ac\uc2a4\ud06c \uc774\ud6c4 \ucf54\uc2a4\ud53c\uac00 \ud55c \ub2ec \ub0b4 \ud68c\ubcf5\ud588\ub2e4\ub294 \ud1b5\uacc4\ub294 \uc2dc\uc7a5\uc774 \ud2b9\uc815 \uc139\ud130\uc758 \uc218\ud61c\ub97c \ucc3e\uac70\ub098, \ub2e8\uae30\uc801 \ucda9\uaca9 \uc774\ud6c4 \ud68c\ubcf5 \ud0c4\ub825\uc131\uc744 \ubcf4\uc5ec\uc904 \uac83\uc774\ub77c\ub294 \uae30\ub300\uac00 \ubcf5\ud569\uc801\uc73c\ub85c \uc791\uc6a9\ud558\uace0 \uc788\uc74c\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \uce74\ud0c0\ub974 LNG \uc0dd\uc0b0 \uc911\ub2e8\uacfc \uac19\uc740 \uacf5\uae09 \uce21\uba74\uc758 \uc2ec\uac01\ud55c \uad50\ub780\uc740 \ub2e8\uc21c\ud788 \ub2e8\uae30\uc801 \ud68c\ubcf5\uc73c\ub85c \uce58\ubd80\ud558\uae30 \uc5b4\ub824\uc6b4 \uad6c\uc870\uc801\uc778 \uc778\ud50c\ub808\uc774\uc158 \uc555\ub825\uacfc \uacbd\uae30 \ub454\ud654 \uac00\ub2a5\uc131\uc744 \ub192\uc785\ub2c8\ub2e4. \uc815\ubd80\uc758 \uc911\ub3d9 \uccb4\ub958\uc790 \ub300\ud53c \uacc4\ud68d \uc218\ub9bd\uc740 \uc0c1\ud669\uc758 \uc2ec\uac01\uc131\uc744 \ubc29\uc99d\ud569\ub2c8\ub2e4.</p> <p>\uc774\ub7ec\ud55c \uc0c1\ud669\uc5d0\uc11c\ub3c4 \uc5d4\ube44\ub514\uc544\uac00 \uad11\uc790\uacf5\ud559 \uc5c5\uccb4\uc5d0 5.8\uc870\uc6d0\uc744 \ud22c\uc790\ud558\ub294 \uc18c\uc2dd\uc740, \uac70\uc2dc\uacbd\uc81c\uc758 \ubd88\ud655\uc2e4\uc131\uc5d0\ub3c4 \ubd88\uad6c\ud558\uace0 \uc778\uacf5\uc9c0\ub2a5(AI)\uacfc \uac19\uc740 \ucca8\ub2e8 \uae30\uc220 \ubd84\uc57c\uc758 \uc7a5\uae30\uc801\uc778 \uc131\uc7a5 \uc7a0\uc7ac\ub825\uc5d0 \ub300\ud55c \ud655\uace0\ud55c \ubbff\uc74c\uc774 \uc5ec\uc804\ud788 \uc874\uc7ac\ud568\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4. \uc774\ub294 \uc2dc\uc7a5 \uc804\ubc18\uc758 \uce68\uccb4 \uc18d\uc5d0\uc11c\ub3c4 \uc120\ud0dd\uc801\uc778 \uc131\uc7a5 \ub3d9\ub825\uc744 \ucc3e\uc544\uc57c \ud558\ub294 \ub2f9\uc704\uc131\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.</p> <p>\ud22c\uc790 \uc804\ub7b5:</p> <p>\ud604 \uc2dc\uc810\uc5d0\uc11c \ud22c\uc790 \uc804\ub7b5\uc740 \uc704\ud5d8 \uad00\ub9ac \ucd5c\uc6b0\uc120 \ubc0f \uc120\ud0dd\uc801 \uc131\uc7a5 \ub3d9\ub825 \ud655\ubcf4\uc5d0 \uc9d1\uc911\ud574\uc57c \ud569\ub2c8\ub2e4.</p> <ol> <li> <p>\ubc29\uc5b4\uc801 \uc790\uc0b0 \ubc30\ubd84 \uac15\ud654:</p> <ul> <li>\ud604\uae08 \ube44\uc911 \ud655\ub300: \uadf9\uc2ec\ud55c \ubd88\ud655\uc2e4\uc131 \uc2dc\uae30\uc5d0\ub294 \uc720\ub3d9\uc131 \ud655\ubcf4\uac00 \uc911\uc694\ud569\ub2c8\ub2e4. \ucd94\uac00\uc801\uc778 \uc2dc\uc7a5 \ud558\ub77d \uc2dc \ub9e4\uc218 \uae30\ud68c \ud3ec\ucc29 \ubc0f \uc2ec\ub9ac\uc801 \uc548\uc815\uac10\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.</li> <li>\uae08, \ub2ec\ub7ec \ub4f1 \uc548\uc804\uc790\uc0b0 \ud3b8\uc785 \uace0\ub824: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc2ec\ud654\ub294 \uc804\ud1b5\uc801\uc778 \uc548\uc804\uc790\uc0b0 \uc120\ud638\ub97c \uac15\ud654\uc2dc\ud0b5\ub2c8\ub2e4.</li> <li>\ubc29\uc5b4\uc801 \uc139\ud130 \ud22c\uc790: \ud544\uc218 \uc18c\ube44\uc7ac, \uc720\ud2f8\ub9ac\ud2f0, \ud5ec\uc2a4\ucf00\uc5b4 \ub4f1 \uacbd\uae30 \ubc29\uc5b4\uc801\uc778 \uc131\uaca9\uc774 \uac15\ud55c \uc139\ud130\uc5d0 \ub300\ud55c \ube44\uc911 \ud655\ub300\uac00 \ud544\uc694\ud569\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c \uc218\ud61c/\ub300\uc751 \uc139\ud130 \uc120\ubcc4 \ud22c\uc790:</p> <ul> <li>\ubc29\uc704\uc0b0\uc5c5: \uc911\ub3d9 \ubd84\uc7c1 \uc2ec\ud654\ub85c \uc778\ud55c \uad6d\ubc29\ube44 \uc99d\uc561 \uae30\ub300\uac10\uc740 \ubc29\uc704\uc0b0\uc5c5 \uae30\uc5c5\ub4e4\uc5d0 \uae0d\uc815\uc801\uc778 \ubaa8\uba58\ud140\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub2e4\ub9cc, \ub2e8\uae30 \uacfc\uc5f4 \uc591\uc0c1\uc5d0 \ub300\ud55c \uc8fc\uc758\uac00 \ud544\uc694\ud569\ub2c8\ub2e4.</li> <li>\uc5d0\ub108\uc9c0 (\uc120\ubcc4\uc801 \uc811\uadfc): \uc720\uac00 \ubcc0\ub3d9\uc131\uc774 \uadf9\uc2ec\ud558\ubbc0\ub85c, \uc9c1\uc811\uc801\uc778 \uc6d0\uc720/LNG \ud22c\uc790\ubcf4\ub2e4\ub294 \uc5d0\ub108\uc9c0 \uc804\ud658(\uc7ac\uc0dd\uc5d0\ub108\uc9c0) \uad00\ub828 \uae30\uc5c5\uc774\ub098, \uc0dd\uc0b0 \ube44\uc6a9 \uc6b0\uc704\uac00 \uba85\ud655\ud558\uace0 \uc9c0\uc815\ud559\uc801 \uc704\ud5d8 \ub178\ucd9c\uc774 \uc801\uc740 \uc5d0\ub108\uc9c0 \uae30\uc5c5\uc5d0 \ub300\ud55c \uc7a5\uae30\uc801 \uad00\uc810\uc758 \uc811\uadfc\uc774 \uc720\ud6a8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> <li>\uc0ac\uc774\ubc84 \ubcf4\uc548: \uc544\ub9c8\uc874 \ub370\uc774\ud130\uc13c\ud130 \uacf5\uaca9 \uc0ac\ub840\uc5d0\uc11c \ubcf4\ub4ef\uc774, \uc0ac\uc774\ubc84 \ubcf4\uc548 \uc704\ud611\uc740 \ub354\uc6b1 \ucee4\uc9c8 \uac83\uc785\ub2c8\ub2e4. \uc774 \ubd84\uc57c\uc758 \uae30\uc220\ub825 \uc788\ub294 \uae30\uc5c5\ub4e4\uc740 \uad6c\uc870\uc801\uc778 \uc131\uc7a5 \uae30\ud68c\ub97c \uac00\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\uc7a5\uae30 \uc131\uc7a5 \ub3d9\ub825\uc73c\ub85c\uc11c\uc758 \uae30\uc220 \uc139\ud130:</p> <ul> <li>AI \ubc0f \ucca8\ub2e8 \uae30\uc220 (\uc120\ud0dd\uc801 \ud22c\uc790): \uc5d4\ube44\ub514\uc544\uc758 \ud22c\uc790\uac00 \uc2dc\uc0ac\ud558\ub4ef, AI, \ubc18\ub3c4\uccb4(\ud2b9\ud788 AI \ubc18\ub3c4\uccb4), \uad11\uc790\uacf5\ud559 \ub4f1 \ubbf8\ub798 \ud575\uc2ec \uae30\uc220 \ubd84\uc57c\ub294 \uac70\uc2dc\uacbd\uc81c \ud658\uacbd\uacfc \ubb34\uad00\ud558\uac8c \uc7a5\uae30\uc801\uc778 \uc131\uc7a5 \uada4\ub3c4\ub97c \uc720\uc9c0\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4. \ud601\uc2e0\uc801 \uae30\uc220\ub825\uc744 \ubcf4\uc720\ud558\uace0 \uc7ac\ubb34\uc801\uc73c\ub85c \uacac\uace0\ud55c \uae30\uc5c5\uc5d0 \ub300\ud55c \uc120\ubcc4\uc801 \ud22c\uc790\ub294 \uc720\ud6a8\ud569\ub2c8\ub2e4.</li> <li>\ud074\ub77c\uc6b0\ub4dc \ucef4\ud4e8\ud305 \ubc0f \ub370\uc774\ud130 \uc778\ud504\ub77c: \ub370\uc774\ud130\uc13c\ud130 \uacf5\uaca9\uc740 \uc624\ud788\ub824 \ub370\uc774\ud130 \uc548\uc815\uc131\uacfc \ud074\ub77c\uc6b0\ub4dc \uc11c\ube44\uc2a4\uc758 \uc911\uc694\uc131\uc744 \ubd80\uac01\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uad00\ub828 \uc778\ud504\ub77c \ubc0f \uc11c\ube44\uc2a4 \uc81c\uacf5 \uae30\uc5c5\uc5d0 \ub300\ud55c \uad00\uc2ec\uc744 \uc720\uc9c0\ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul> </li> <li> <p>\ud55c\uad6d \uc2dc\uc7a5 (\ucf54\uc2a4\ud53c) \uc811\uadfc \uc804\ub7b5:</p> <ul> <li>'\uc774\ubc88\uc5d4 \ud3ec\ubaa8 \uc5c6\ub2e4'\ub294 \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc758 \uc2ec\ub9ac\ub294 \uacfc\ub3c4\ud55c \ud22c\uae30 \uc2ec\ub9ac \uc5b5\uc81c\uc5d0 \uae0d\uc815\uc801\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uacfc\uac70 \uc911\ub3d9 \ub9ac\uc2a4\ud06c \uc2dc \ucf54\uc2a4\ud53c\uc758 \ud68c\ubcf5 \ud0c4\ub825\uc131\uc744 \uace0\ub824\ud558\ub418, \ud604\uc7ac\uc758 \uc9c0\uc815\ud559\uc801 \uc0c1\ud669\uc740 \uacfc\uac70\ubcf4\ub2e4 \ubcf5\ud569\uc801\uc774\uace0 \uc2ec\uac01\ud560 \uc218 \uc788\uc74c\uc744 \uc778\uc9c0\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc8fc\uc694 \uc218\ucd9c \uae30\uc5c5\uc758 \uc5d0\ub108\uc9c0 \ube44\uc6a9 \uc99d\uac00\uc640 \uc911\ub3d9\ud5a5 \uc218\ucd9c \uac10\uc18c \uac00\ub2a5\uc131\uc744 \uba74\ubc00\ud788 \uc8fc\uc2dc\ud558\uba70, \ub0b4\uc218 \uae30\ubc18\uc774 \uc0c1\ub300\uc801\uc73c\ub85c \uac15\ud558\uac70\ub098 \uc5d0\ub108\uc9c0 \ud6a8\uc728\uc131\uc774 \ub192\uc740 \uae30\uc5c5\uc744 \uc120\ubcc4\ud558\ub294 \uc804\ub7b5\uc774 \ud544\uc694\ud569\ub2c8\ub2e4.</li> </ul> </li> </ol> <p>\uc885\ud569\uc801\uc73c\ub85c, \ud604\uc7ac\ub294 \uadf9\ub3c4\uc758 \uc2e0\uc911\ud568\uc774 \uc694\uad6c\ub418\ub294 \uc2dc\uae30\uc785\ub2c8\ub2e4. \ub2e8\uae30\uc801 \ubcc0\ub3d9\uc131\uc5d0 \uc77c\ud76c\uc77c\ube44\ud558\uae30\ubcf4\ub2e4, \ud3ec\ud2b8\ud3f4\ub9ac\uc624\uc758 \uc548\uc815\uc131\uc744 \ud655\ubcf4\ud558\uace0, \uc704\uae30\ub97c \uae30\ud68c\ub85c \uc0bc\uc744 \uc218 \uc788\ub294 \uc7a5\uae30 \uc131\uc7a5 \ub3d9\ub825 \ubc0f \ubc29\uc5b4\uc801 \uc139\ud130\uc5d0 \ub300\ud55c \uc120\ubcc4\uc801 \uc811\uadfc\uc744 \ud1b5\ud574 \uc2dc\uc7a5\uc758 \ud750\ub984\uc5d0 \ub300\uc751\ud574\uc57c \ud560 \uac83\uc785\ub2c8\ub2e4.</p>"},{"location":"reports/2026-03-02/#_4","title":"\u26a0\ufe0f \uc8fc\uc758 \uae4a\uac8c \ubd10\uc57c \ud560 \uc9c0\ud45c\ub098 \uc77c\uc815","text":"<p>\ud604\uc7ac\uc758 \ubd88\ud655\uc2e4\uc131\uc744 \uac10\uc548\ud560 \ub54c, \ub2e4\uc74c \uc9c0\ud45c \ubc0f \uc77c\uc815\uc5d0 \ub300\ud55c \uba74\ubc00\ud55c \ubaa8\ub2c8\ud130\ub9c1\uc774 \ud544\uc218\uc801\uc785\ub2c8\ub2e4.</p> <ol> <li> <p>\uc911\ub3d9 \uc9c0\uc815\ud559\uc801 \uc804\uac1c \uc0c1\ud669:</p> <ul> <li>\ubd84\uc7c1\uc758 \ud655\uc804 \ub610\ub294 \uc644\ud654 \uc5ec\ubd80: \uc774\ub780\uacfc \uc778\uadfc \uad6d\uac00 \uac04\uc758 \ucd94\uac00\uc801\uc778 \uad70\uc0ac \ud589\ub3d9, \uc8fc\uc694 \uc778\ud504\ub77c \uacf5\uaca9 \uc5ec\ubd80, \uad6d\uc81c \uc0ac\ud68c\uc758 \uc911\uc7ac \ub178\ub825 \uc9c4\ud589 \uc0c1\ud669.</li> <li>\uc8fc\uc694 \uad6d\uac00\ub4e4\uc758 \uacf5\uc2dd \uc785\uc7a5 \ubcc0\ud654: \ubbf8\uad6d, \uc720\ub7fd, \uc911\uad6d, \ub7ec\uc2dc\uc544 \ub4f1 \uc8fc\uc694 \uac15\ub300\uad6d\ub4e4\uc758 \uc678\uad50\uc801/\uad70\uc0ac\uc801 \uac1c\uc785 \uac15\ub3c4.</li> <li>\uc911\ub3d9 \uccb4\ub958\uc790 \ub300\ud53c \ubc0f \uc778\ub3c4\uc8fc\uc758\uc801 \uc704\uae30 \uc0c1\ud669: \uc815\ubd80\uc758 \ub300\ucc45 \ubc0f \uc9c4\ud589 \uc0c1\ud669.</li> </ul> </li> <li> <p>\uae00\ub85c\ubc8c \uc5d0\ub108\uc9c0 \uc2dc\uc7a5 \uc9c0\ud45c:</p> <ul> <li>\uad6d\uc81c \uc720\uac00 (WTI, \ube0c\ub80c\ud2b8\uc720): 100\ub2ec\ub7ec \uc120 \ub3cc\ud30c \uc9c0\uc18d \uc5ec\ubd80 \ubc0f \ucd94\uc774.</li> <li>\ucc9c\uc5f0\uac00\uc2a4 \uac00\uaca9 (LNG): \uce74\ud0c0\ub974 \uc2dc\uc124 \ubcf5\uad6c \uc5ec\ubd80 \ubc0f \uae00\ub85c\ubc8c LNG \uacf5\uae09 \ucc28\uc9c8\uc5d0 \ub530\ub978 \uac00\uaca9 \uae09\ub4f1\uc138.</li> <li>\uc8fc\uc694 \uc5d0\ub108\uc9c0 \uc0dd\uc0b0\uad6d\uc758 \uc0dd\uc0b0\ub7c9 \ubcc0\ud654: OPEC+ \ud68c\uc758 \uacb0\uacfc \ubc0f \uc0ac\uc6b0\ub514\uc544\ub77c\ube44\uc544 \ub4f1 \uc8fc\uc694 \uc0b0\uc720\uad6d\uc758 \uc99d\uc0b0/\uac10\uc0b0 \uc6c0\uc9c1\uc784.</li> <li>\uad6d\uc81c \uc5d0\ub108\uc9c0 \uae30\uad6c(IEA)\uc758 \uc6d4\uac04 \ubcf4\uace0\uc11c \ubc0f \uc804\ub9dd\uce58.</li> </ul> </li> <li> <p>\uae00\ub85c\ubc8c \uacbd\uc81c \uc9c0\ud45c:</p> <ul> <li>\uc8fc\uc694\uad6d\uc758 \uc778\ud50c\ub808\uc774\uc158 \uc9c0\ud45c (CPI, PPI): \uc5d0\ub108\uc9c0 \uac00\uaca9 \uae09\ub4f1\uc774 \ubb3c\uac00\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5 \ud655\uc778.</li> <li>\uc81c\uc870\uc5c5 \uad6c\ub9e4\uad00\ub9ac\uc790\uc9c0\uc218 (PMI), \uc0b0\uc5c5\uc0dd\uc0b0 \uc9c0\ud45c: \uacf5\uae09\ub9dd \uad50\ub780 \ubc0f \uc5d0\ub108\uc9c0 \ube44\uc6a9 \uc0c1\uc2b9\uc774 \uc2e4\ubb3c \uacbd\uc81c\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5.</li> <li>\uc18c\ube44\uc790 \uc2ec\ub9ac \uc9c0\uc218: \uace0\uc720\uac00\uc640 \ubd88\ud655\uc2e4\uc131\uc774 \uc18c\ube44 \uc2ec\ub9ac\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5.</li> <li>\uae00\ub85c\ubc8c \uad50\uc5ed\ub7c9 \uc9c0\ud45c: \uc9c0\uc815\ud559\uc801 \ub9ac\uc2a4\ud06c\uac00 \uad6d\uc81c \ubb34\uc5ed\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5.</li> </ul> </li> <li> <p>\uc8fc\uc694 \uae08\uc735 \uc2dc\uc7a5 \uc9c0\ud45c:</p> <ul> <li>\uae00\ub85c\ubc8c \uc99d\uc2dc \uc8fc\uc694 \uc9c0\uc218 (S&amp;P 500, NASDAQ, Nikkei, KOSPI): \uc77c\uac04 \ubc0f \uc8fc\uac04 \ubcc0\ub3d9\uc131 \ucd94\uc774.</li> <li>\ubcc0\ub3d9\uc131 \uc9c0\uc218 (VIX): \uc2dc\uc7a5\uc758 \ubd88\uc548\uac10 \uc815\ub3c4\ub97c \uce21\uc815.</li> <li>\ud658\uc728 (\ub2ec\ub7ec \uc778\ub371\uc2a4, \uc6d0/\ub2ec\ub7ec \ud658\uc728): \uc704\uae30 \uc2dc \uc548\uc804\uc790\uc0b0 \uc120\ud638\uc5d0 \ub530\ub978 \ub2ec\ub7ec \uac15\uc138 \uc555\ub825.</li> <li>\uad6d\ucc44 \uae08\ub9ac: \uc548\uc804\uc790\uc0b0 \uc120\ud638\uc5d0 \ub530\ub978 \uad6d\ucc44 \ub9e4\uc218\uc138 \ubc0f \uae08\ub9ac \ud558\ub77d \uc5ec\ubd80.</li> </ul> </li> <li> <p>\uc8fc\uc694 \uae30\uc5c5 \uc2e4\uc801 \ubc1c\ud45c \ubc0f \ud22c\uc790 \ub3d9\ud5a5:</p> <ul> <li>\uc5d0\ub108\uc9c0 \ube44\uc6a9 \uc0c1\uc2b9\uc5d0 \ucde8\uc57d\ud55c \uc0b0\uc5c5\uad70\uc758 \uc2e4\uc801 \uacbd\uace0.</li> <li>\ud074\ub77c\uc6b0\ub4dc, AI \ub4f1 \uace0\uc131\uc7a5 \uae30\uc220 \uae30\uc5c5\ub4e4\uc758 \ud22c\uc790 \uacc4\ud68d \ubc0f \uc131\uc7a5\uc138 \uc9c0\uc18d \uc5ec\ubd80.</li> </ul> </li> </ol> <p>\uc774\ub7ec\ud55c \uc9c0\ud45c\ub4e4\uacfc \uc77c\uc815\ub4e4\uc744 \uc885\ud569\uc801\uc73c\ub85c \ubd84\uc11d\ud558\uba70, \uae09\ubcc0\ud558\ub294 \uc2dc\uc7a5 \uc0c1\ud669\uc5d0 \uc720\uc5f0\ud558\uac8c \ub300\ucc98\ud560 \uc218 \uc788\ub294 \ud22c\uc790 \uc804\ub7b5\uc744 \uc218\ub9bd\ud558\ub294 \uac83\uc774 \uc911\uc694\ud569\ub2c8\ub2e4.</p>"}]}